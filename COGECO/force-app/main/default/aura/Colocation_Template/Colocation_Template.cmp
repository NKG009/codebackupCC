<aura:component implements="lightning:homeTemplate" description="Colocation">
    
    <!-- Header -->
    <aura:attribute name="header1a" type="Aura.Component[]" />
    <aura:attribute name="header1b" type="Aura.Component[]" />
    <aura:attribute name="header2a" type="Aura.Component[]" />
    <aura:attribute name="header2b" type="Aura.Component[]" />
    <aura:attribute name="header2c" type="Aura.Component[]" />
    <aura:attribute name="header2d" type="Aura.Component[]" />
    <aura:attribute name="header2e" type="Aura.Component[]" />
    <aura:attribute name="header2f" type="Aura.Component[]" />
    
    
    <!-- Two Columns -->
  	<aura:attribute name="left_col" type="Aura.Component[]" />
  	<aura:attribute name="mid_col" type="Aura.Component[]" />
  	<aura:attribute name="right_col" type="Aura.Component[]" />
     
    
    <!-- Footer -->
    <aura:attribute name="footer1" type="Aura.Component[]" />
    
    
    <!-- Layout -->
    
    <div>
    
        <!-- Row 1 -->
    	<lightning:layout>
        
        	<lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header1a}
            </lightning:layoutitem>        	
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '10' : '10' }" class="">
                {!v.header1b}
            </lightning:layoutitem>
        
        </lightning:layout>
     
              <!-- Row 2 -->
      <!--  <lightning:layout>
        
        	<lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2a}
            </lightning:layoutitem>        	
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2b}
            </lightning:layoutitem>
        	<lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2c}
            </lightning:layoutitem>        	
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2d}
            </lightning:layoutitem>
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2e}
            </lightning:layoutitem>        	
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '2' : '2' }" class="">
                {!v.header2f}
            </lightning:layoutitem>
    
        </lightning:layout>       
        -->
        
        <!-- Row 3 -->
    	<lightning:layout>
        
       	 
            <lightning:layoutitem size="{! $Browswer.isDesktop ? '12' : '12' }" class="">
                {!v.mid_col}
            </lightning:layoutitem>

            
        </lightning:layout>         
     
        <!-- Row 4 -->
    	<lightning:layout>
        
        	<lightning:layoutitem size="{! $Browswer.isDesktop ? '12' : '12' }" class="">
                {!v.footer1}
            </lightning:layoutitem>  
            
        </lightning:layout> 
        
    </div>
	
</aura:component>