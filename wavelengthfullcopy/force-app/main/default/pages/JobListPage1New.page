		<script>
			$(document).ready(function () {
				var pageNumber = '{!pageNumber}';
				$('.empty').each(function () {
					
					if ($(this).text() === pageNumber) {
						$(this).addClass('lightLinkPage');
					}
				});
				var paging = $('#paging').clone(true);
				$('#afterInsertPaging').after(paging);
				window.scrollTo(0, 0);
				parent.scrollTo(0, 0);
			});
			
			function goToThisJob(id) {
				document.getElementById(JobId).value = id;
				alert(document.getElementById('JobId').value);
				return true;
			}
			
			function applyCheckBoxClick(inputCheck) {
				checkId = inputCheck.id;
				var checkIdList = checkId.split(':');
				size = checkIdList.length;
				
				checkName = checkIdList[size - 1];
				//checkName1 = ':'+checkName;
				baseIdPart = checkId.replace(checkName, '');
				
				var i = 0;
				var j = 0;
				if (inputCheck.checked == true) {
					
					while (document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox')) {
						if (document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox').disabled == false) {
							document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox').checked = true;
						}
						j++;
						if (j == 999) {
							i++;
							j = 0;
						}
					}
					
				} else {
					while (document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox')) {
						if (document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox').disabled == false) {
							document.getElementById(baseIdPart + 'repeat1:' + i + ':repeat2:' + j + ':checkBox').checked = false;
						}
						j++;
						if (j == 999) {
							i++;
							j = 0;
						}
					}
					var selecJobs = document.getElementById('{!$Component.page.form1.selectedJobs}').value;
					var jobs = new Array();
					jobs = selecJobs.split(';');
					
					//alert(jobs[1]);
					var jobsList = document.getElementById('{!$Component.page.form1.jobIdsPerPage}').value;
					var jobListArray = new Array();
					jobsListArray = jobsList.split(';');
					//alert(jobsListArray[1]);
					
					for (var i = 0; i < jobs.length; i++) {
						for (var j = 0; j < jobsListArray.length; j++) {
							if (jobsListArray[j] === jobs[i]) {
								
								selecJobs = selecJobs.replace(jobs[i], "");
								selecJobs = selecJobs.replace(';', "");
							}
							
						}
						
					}
					//alert(selecJobs);
					document.getElementById('{!$Component.page.form1.selectedJobs}').value = selecJobs;
					
				}
			}
			
			function checkForJobAlreadySelected(inputCheck, jobId) {
				
				if (inputCheck.checked == false) {
					var selecJobs = document.getElementById('{!$Component.page.form1.selectedJobs}').value;
					if (selecJobs.length != 0) {
						//alert(selecJobs);
						selecJobs = selecJobs.replace(jobId + ';', "");
						document.getElementById('{!$Component.page.form1.selectedJobs}').value = selecJobs;
						//alert(selecJobs);
					}
					
				}
				
			}
			
			function autoResizeIframe() {
				var iframesEle = window.parent.document.getElementsByTagName('Iframe');
				for (var i = 0; i < iframesEle.length; i++) {
					var newHeight;
					
					if (iframesEle[i].contentDocument) {
						newHeight = iframesEle[i].contentDocument.documentElement.scrollHeight + 200 + 'px'; //FF 3.0.11, Opera 9.63, and Chrome
					} else {
						newHeight = iframesEle[i].contentWindow.document.body.scrollHeight + 200 + 'px'; //IE6, IE7 and Chrome
					}
					iframesEle[i].style.height = newHeight;
					iframesEle[i].parentNode.parentNode.style.height = newHeight;
				}
			}
			
			autoResizeIframe();
		</script>
	</div>
</apex:page>