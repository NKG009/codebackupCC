<apex:page controller="JobListViewComponentController1" title="{!$Label.TRGTFCMS__Job_List_Page}"
		standardstylesheets="true" showHeader="false" sideBar="false" cache="false" action="{!init}"
		language="{!selectLanguage}" id="page">
	
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport"
				content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0"/>
		<meta name="keywords" content="{!metaKeywords}" id="keywords"/>

		<apex:stylesheet value="{!URLFOR($Resource.TRGTFCMS__Bootstrap_3_4_1, '/css/bootstrap.min.css')}"/>
		<apex:includeScript value="{!URLFOR($Resource.TRGTFCMS__Jquery_3_6_0)}"/>
		<apex:includeScript value="{!URLFOR($Resource.TRGTFCMS__Bootstrap_3_4_1, '/js/bootstrap.min.js')}"/>

		<apex:includeScript value="{!$Resource.TRGTFCMS__LinkedIn}"/>
		
		<script type="text/javascript">
			function fixId(myid) {
				return '#' + myid.replace(new RegExp("(:|\\.)", "g"), '\\\$1');
			}
			
			function CreateBookmarkLink(a) {
				title = document.title;
				url = document.location;
				try {
					// Internet Explorer
					window.external.AddFavorite(url, title);
				} catch (e) {
					try {
						// Mozilla
						window.sidebar.addPanel(title, url, "");
					} catch (e) {
						// Opera
						if (typeof (opera) == "object") {
							a.rel = "sidebar";
							a.title = title;
							a.url = url;
							return true;
						} else {
							// Unknown
							alert('Press Ctrl-D to add page to your bookmarks');
						}
					}
				}
				return false;
			}
			
			function linkedinCompany() {
				new LinkedIn.CompanyInsiderPopup("acumen", " {!JSENCODE(org.Name)}");
			}
			
			function apply() {
				var otherPagesSelectedJobIds = '{!selectedJobsPagination}'.split(';').filter(Boolean);
				
				var $checkedCheckboxes = $('.tableJobList input[type="checkbox"]:checked:enabled');
				var currentPageSelectedJobIds = [];
				$checkedCheckboxes.each(function (index) {
					currentPageSelectedJobIds.push($checkedCheckboxes.eq(index).attr('jobId'));
				});
				
				var allSelectedJobIds = otherPagesSelectedJobIds.concat(currentPageSelectedJobIds);
				if (allSelectedJobIds.length == 0) {
					alert('{!$Label.AVTRRT__Please_select_at_least_one_job}');
					return;
				}
				
				window.open(
						'/apex/FCMS__CMSLayout?jobSite={!JSENCODE($CurrentPage.parameters.jobSite)}' +
						'&p={!if($CurrentPage.parameters.p == null,'',JSENCODE($CurrentPage.parameters.p))}' +
						'&page=JobApplicationPage&sessionId={!if($CurrentPage.parameters.sessionId == null, '',JSENCODE($CurrentPage.parameters.sessionId))}' +
						'&source={!JSENCODE($CurrentPage.parameters.source)}&jobIds='
						+ allSelectedJobIds.join(';'), '_parent');
			}
		</script>
		
		<style type="text/css">
			<apex:outputText value="{!cmsCssCustom}"/>
		</style>
	</head>
	
