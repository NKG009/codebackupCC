<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>52.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Portal V2 - Navigation Menu</masterLabel>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property
        name="menuName"
        type="String"
        default="Default Navigation"
        label="Navigation Menu Name"
        description="The name of the Navigation Menu Linkset, which can be configured in Settings > Navigation"
      />
            <property
        name="settingsPath"
        type="String"
        default="/cpv2/s/settings"
        label="Settings Path"
        description="The url for the settings cog's href"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>