<aura:component implements="forceCommunity:availableForAllPageTypes"  controller="SiteManagementComponentController" access="global" >
    <aura:attribute name="brand" type="String" default="Tate" />
    <aura:attribute name="brandDetails" type="Brand__mdt" />
    <aura:attribute name="year" type="String" />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <div><table style="margin: 40px 0px 60px 0px;">
            <tr>
                <td class="slds-align_absolute-center">© {!v.brand}, All rights reserved {!v.year}.</td>
            </tr>
            <tr>
                <td class="slds-align_absolute-center">Registered Address {!v.brandDetails.Registered_Address__c}. Company No. {!v.brandDetails.Registration_No__c}</td>
            </tr>
        </table></div>
   
</aura:component>