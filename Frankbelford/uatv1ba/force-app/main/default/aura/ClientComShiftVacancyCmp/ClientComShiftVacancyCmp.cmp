<!-- NewVacancyComponent -->
<aura:component controller="SendEmailOnNewVacancy" implements="forceCommunity:availableForAllPageTypes" access="global" description="ClientComShiftVacancyCmp">
    <ltng:require styles="{!join(',',
                          $Resource.webUI+'/assets/css/all.css',
                          $Resource.webUI+'/assets/css/fontawesome.css',
                          $Resource.webUI+'/assets/css/fontawesome.min.css',
                          $Resource.webUI+'/assets/css/custom.css',
                          $Resource.Tjcss2+'/assets/css/main.css',
                           $Resource.Tjcss2+'/assets/css/custom.css'
                          )
                          }"
                  scripts="{!join(',',
                           $Resource.Tjcss+'/assets/js/main.min.js',
                           $Resource.Tjcss2+'/assets/js/zoom.js',
                           $Resource.webUI+'/assets/js/custom.js'
                           )}"
    />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="siteList" type="List" access="global"/>
    <aura:attribute name="jobSiteList" type="List" access="global"/>
    <aura:attribute name="isOpen" type="boolean" access="global"/>
    <aura:attribute name="message" type="String" access="global"/>
    <aura:attribute name="isSiteEmpty" type="boolean" access="global"/>
    <aura:attribute name="isStartDateEmpty" type="boolean" access="global"/>
    <aura:attribute name="isEndDateEmpty" type="boolean" access="global"/>
    <aura:attribute name="startDateSelected" type="Date" access="global" />
    <aura:attribute name="endDateSelected" type="Date" access="global"/>
    <aura:attribute name="textAreaValue" type="String" access="global"/>
    <aura:attribute name="selectedSite" type="String" access="global"/>
    <aura:attribute name="userInfo" type="User"/>
    <aura:attribute name="site" type="String" />

 
