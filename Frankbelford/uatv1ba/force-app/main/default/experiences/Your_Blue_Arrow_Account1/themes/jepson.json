footer-link\">Client Portal</a>\n                            </div>\n\n                            <div style=\"width: 22%;\">\n                                <strong>Company</strong><br><br>\n                                <a href=\"/company\" class=\"footer-link\">Company Overview</a>\n                                <a href=\"/about-us\" class=\"footer-link\">About Us</a>\n                                <a href=\"/contact-us\" class=\"footer-link\">Contact Us</a>\n                            </div>\n\n                            <div style=\"width: 22%;\">\n                                <strong>Corporate Governance</strong><br><br>\n                                <a href=\"/corporate-governance\" class=\"footer-link\">Governance Overview</a>\n                                <a href=\"/privacy-policy\" class=\"footer-link\">Privacy Policy</a>\n                                <a href=\"/data-access-request\" class=\"footer-link\">Data Access Request</a>\n                            </div>\n\n                        </div>\n\n\n\n\n                        <!-- Company Details Section -->\n                        <div\n                            style=\"width: 100%; display: flex; flex-direction: column; align-items: flex-start; margin-top: 70px; gap: 10px;\">\n                            <div style=\"text-align: left; color: white; font-size: 12px;\">\n\n                                <!-- Social Media Icons -->\n                                <div style=\"margin-bottom: 15px;\">\n                                    <a href=\"https://www.facebook.com/BlueArrowJobs\" target=\"_blank\"\n                                        style=\"margin-right: 10px;\">\n                                        <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741108478000/BAFacebook\" alt=\"Facebook\" style=\"width: 24px; height: 24px;\">\n                                    </a>\n                                    <a href=\"https://www.linkedin.com/company/blue-arrow\" target=\"_blank\"\n                                        style=\"margin-right: 10px;\">\n                                        <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741108439000/BALinkedIn\" alt=\"LinkedIn\" style=\"width: 24px; height: 24px;\">\n                                    </a>\n                                    <a href=\"https://twitter.com/bluearrowgroup\" target=\"_blank\"\n                                        style=\"margin-right: 10px;\">\n                                        <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741108494000/BAX\" alt=\"Twitter\" style=\"width: 24px; height: 24px;\">\n                                    </a>\n                                    <a href=\"https://www.youtube.com/channel/UCN1X-rcqNOXv0fLbhtNnJJQ\" target=\"_blank\">\n                                        <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741108460000/BAYoutube\" alt=\"YouTube\" style=\"width: 24px; height: 24px;\">\n                                    </a>\n                                </div>\n\n                                <!-- Get in Touch with Arrow Icon -->\n                                <a href=\"your_salesforce_community_link\" class=\"get-in-touch\">\n                                    Get in touch\n                                    <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741107606000/BAArrow\"\n                        alt=\"Arrow\"\n                        style=\"width: 14px; height: 14px; margin-left: 5px;\">\n                                </a> &nbsp;&nbsp; | &nbsp;&nbsp;\n\n                                <!-- Location Icon Before Address -->\n                                <img src=\"https://blue-arrow--uat--c.sandbox.vf.force.com/resource/1741107628000/BALocation\"\n                    alt=\"Location\"\n                    style=\"width: 14px; height: 16px; vertical-align: middle; margin-