<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Company_Reg_No_Format</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(REGEX(IP_CompanyRegNo__c,&quot;[0-9]{8}|[a-zA-Z]{2}[0-9]{6}&quot;))</errorConditionFormula>
    <errorDisplayField>IP_CompanyRegNo__c</errorDisplayField>
    <errorMessage>Company Registration no format is : 8 numeric or 2 alpha and 6 numeric</errorMessage>
</ValidationRule>
