<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Worker_Leaving_Date</fullName>
    <active>true</active>
    <errorConditionFormula>IF( IP_WorkerLeavingDate__c &lt; IP_WorkerStartDate__c ,True,False)</errorConditionFormula>
    <errorMessage>Worker leaving date can not be less than worker start date.</errorMessage>
</ValidationRule>
