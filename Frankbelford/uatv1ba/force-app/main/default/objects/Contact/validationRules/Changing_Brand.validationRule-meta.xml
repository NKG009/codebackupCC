<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Changing_Brand</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
				ischanged(Brand__c),
				Brand__c = &quot;Impellam&quot;,
				PRIORVALUE(Brand__c) != &quot;Impellam&quot;
)</errorConditionFormula>
    <errorMessage>You cant update a candidates brand to Impellam</errorMessage>
</ValidationRule>
