<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ContactPersonLinkedToContactClient</fullName>
    <active>false</active>
    <errorConditionFormula>AND(Account.RecordType.DeveloperName = &quot;Account&quot;,
RecordType.DeveloperName !=&quot;Contact&quot;)</errorConditionFormula>
    <errorDisplayField>AccountId</errorDisplayField>
    <errorMessage>Contacts can only be linked to Accounts</errorMessage>
</ValidationRule>
