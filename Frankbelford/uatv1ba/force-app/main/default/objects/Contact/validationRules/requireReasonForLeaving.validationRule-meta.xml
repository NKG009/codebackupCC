<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>requireReasonForLeaving</fullName>
    <active>true</active>
    <errorConditionFormula>and(not(isblank( sirenum__Work_End_Date__c )), isblank(  Reason_for_Leaving__c ))</errorConditionFormula>
    <errorDisplayField>Reason_for_Leaving__c</errorDisplayField>
    <errorMessage>You must enter the reason for leaving</errorMessage>
</ValidationRule>
