<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Salutation_and_PostCode_to_be_mandatory</fullName>
    <active>false</active>
    <errorConditionFormula>ISBLANK(TEXT(Salutation)) || ISBLANK( MailingPostalCode )</errorConditionFormula>
    <errorMessage>Salutation and Postal Code should not be blank</errorMessage>
</ValidationRule>
