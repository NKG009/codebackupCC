<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Next_Birthday__c</fullName>
    <description>Candidates next birthday</description>
    <formula>IF(
			 
DATE(YEAR(TODAY()),MONTH(Birthdate),DAY(Birthdate))  &lt;  TODAY(),DATE(YEAR(TODAY())+1,MONTH(Birthdate),DAY(Birthdate)),DATE(YEAR(TODAY()),MONTH(Birthdate),DAY(Birthdate))
				
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Candidates next birthday</inlineHelpText>
    <label>Next Birthday</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Date</type>
</CustomField>
