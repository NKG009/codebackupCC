<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancel_No_Show_Rule__c</fullName>
    <formula>AND(
				 Last_No_Show_Cancelled_Shift__c&gt;(NOW()-365),
					OR(
				 No_Show_Cancelled_Shifts__c&gt;3,
No_Show_Shifts__c&gt;4))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Cancel/No Show Rule</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
