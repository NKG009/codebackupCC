<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Break_Hours_Maximum</fullName>
    <active>true</active>
    <description>Maximum break hours for specific job.</description>
    <errorConditionFormula>Break__c  &gt; 100 ||
Break__c  &lt; 0</errorConditionFormula>
    <errorDisplayField>Break__c</errorDisplayField>
    <errorMessage>Value must be between 0 and 100 hours.</errorMessage>
</ValidationRule>
