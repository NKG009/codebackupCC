<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>filtered_field_must_have_filter_type</fullName>
    <active>true</active>
    <errorConditionFormula>Filterable__c = TRUE &amp;&amp; ISBLANK(TEXT(Filter_Type__c))</errorConditionFormula>
    <errorMessage>A filterable field must have an associated filter type</errorMessage>
</ValidationRule>
