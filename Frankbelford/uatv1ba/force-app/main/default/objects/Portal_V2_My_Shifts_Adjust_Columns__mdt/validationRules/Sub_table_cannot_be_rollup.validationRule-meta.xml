<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Sub_table_cannot_be_rollup</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(Table_Type__c, &apos;Sub&apos;) &amp;&amp;   Rollup_from_children__c = true</errorConditionFormula>
    <errorMessage>A sub table column cannot act as a rollup</errorMessage>
</ValidationRule>
