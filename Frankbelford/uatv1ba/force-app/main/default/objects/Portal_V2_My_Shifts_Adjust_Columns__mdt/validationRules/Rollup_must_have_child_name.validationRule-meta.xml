<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rollup_must_have_child_name</fullName>
    <active>true</active>
    <errorConditionFormula>Rollup_from_children__c = true &amp;&amp; (ISBLANK(Child_Column_Name__c) || ISBLANK(TEXT( Aggregate_type__c )))</errorConditionFormula>
    <errorMessage>A rollup field must have a child column name and aggregate type</errorMessage>
</ValidationRule>
