<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Unit_ID_or_Purchase_Order</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
				 Unit_ID_Required__c = TRUE,
				 Purchase_Order_Required__c = TRUE)</errorConditionFormula>
    <errorMessage>Unit ID and Purchase Order cannot both be ticked as required</errorMessage>
</ValidationRule>
