<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Candidate_account_editing</fullName>
    <active>true</active>
    <errorConditionFormula>(RecordType.Name ==&quot;Candidate&quot; &amp;&amp; ISCHANGED(Name) &amp;&amp; $Profile.Name &lt;&gt; &apos;System Administrator&apos;)</errorConditionFormula>
    <errorMessage>Only Administrators can rename this Account</errorMessage>
</ValidationRule>
