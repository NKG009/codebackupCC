<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Company_Reg_No_Account</fullName>
    <active>false</active>
    <errorConditionFormula>if(IP_CompanyRegistrationNo__c!=null,NOT(REGEX(IP_CompanyRegistrationNo__c,&quot;[0-9]{8}|[a-zA-Z]{2}[0-9]{6}&quot;)),false)</errorConditionFormula>
    <errorDisplayField>IP_CompanyRegistrationNo__c</errorDisplayField>
    <errorMessage>Company Registration no format is : 8 numeric or 2 alpha and 6 numeric</errorMessage>
</ValidationRule>
