<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Only_Senior_Admin_can_create_2ndTierSupp</fullName>
    <active>true</active>
    <errorConditionFormula>ISNEW() &amp;&amp;  RecordType.DeveloperName = &apos;IP_2ndTierSupplier&apos; &amp;&amp;  
