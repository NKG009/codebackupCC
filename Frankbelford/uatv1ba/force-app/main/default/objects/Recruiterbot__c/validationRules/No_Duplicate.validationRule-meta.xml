<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>No_Duplicate</fullName>
    <active>true</active>
    <errorConditionFormula>(ISNEW() || ISCHANGED(Name)) &amp;&amp; LOWER(VLOOKUP($ObjectType.Recruiterbot__c.Fields.Name, $ObjectType.Recruiterbot__c.Fields.Name , LOWER(Name))) = LOWER(Name)</errorConditionFormula>
    <errorDisplayField>Name</errorDisplayField>
    <errorMessage>This RecruiterBot Name is already in use</errorMessage>
</ValidationRule>
