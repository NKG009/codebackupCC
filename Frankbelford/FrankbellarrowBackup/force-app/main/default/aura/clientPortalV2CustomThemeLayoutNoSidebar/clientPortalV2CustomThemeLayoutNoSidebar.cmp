<aura:component implements="forceCommunity:themeLayout">
  <aura:attribute name="navigation" type="Aura.Component[]" />
  <aura:attribute name="formFactor" type="String" />

  <div class="slds-grid">
    <div class="slds-col slds-size_2-of-12">{!v.navigation}</div>
    <div class="slds-col slds-size_9-of-12">{!v.body}</div>
    <div class="slds-col slds-size_1-of-12"></div>
  </div>
</aura:component>