/**
 * Implement the SirenumEngineExtension to provide maximum hours for calendar week to limit
 * international students to work during term times (replacing RULE-7 & RULE-8)
 * The rule limit the total hours per calendar week for shifts where IP_IntStudentWorkHoursRestriction__c
 * equals '10' or '20', counting all past shifts in the same calendar week (excluding paid breaks).
 */
public without sharing class InternationalStudentWTR implements sirenum.SirenumEngineExtension {
    /**
     * Custom exception for errors in the rule
     */
    public with sharing class WTRException extends Exception {}

    /**
     * A zero time value
     */
    private static final Time ZERO_TIME = Time.newInstance(0, 0, 0, 0);

    /**
     * The number of milliseconds in one hour.
     */
    private static final Decimal MILLISECONDS_PER_HOUR = 3600000.0;

    /**
     * The SirenumEngineExtension entry point
     *
     * @param shifts the list of shifts loaded by the SirenumEngine
     *
     * @return list of alerts generated by the rule
     */
    public List<sirenum__LogEntry__c> execute(List<sirenum.SirenumEngine.Shift> shifts) {
        // Recalculate formula fields so that the correct value of IP_IntStudentWorkHoursRestriction__c is reflected (on the finishDate)
        recalculateFormulasOnCheckedShifts(shifts);

        // Split the shifts into timelines for each contact (in each group)
        List<List<sirenum.SirenumEngine.Shift>> timelines = splitShiftsIntoTimelines(shifts);

        // Get the week ending day, 0-Sun... (default is 6-Sat)
        Integer weekEndingDay = (Integer)sirenum__Shift_Logic__c.getInstance().sirenum__Week_Ending__c;
        if (weekEndingDay == null) {
            weekEndingDay = 6;
        }

        // The generated list of alerts
        List<sirenum__LogEntry__c> alerts = new List<sirenum__LogEntry__c>();

        // Iterate the timelines and generate alerts
        for (List<sirenum.SirenumEngine.Shift> timeline : timelines) {
            // Evaluate the rule for a given timeline and add alerts as needed
            evaluateTimeline(timeline, alerts, weekEndingDay);
        }

        return alerts;
    }

    /**
     * Recalculate formula fields on checked shifts and store the IP_IntStudentWorkHoursRestriction__c value on the
     * finishDate when it is a number
     *
     * @param shifts the list of shifts loaded by the SirenumEngine
     */
    @TestVisible
    private static void recalculateFormulasOnCheckedShifts(List<sirenum.SirenumEngine.Shift> shifts) {
        List<sirenum.SirenumEngine.Shift> shiftsToCheck = new List<sirenum.SirenumEngine.Shift>();
        List<sirenum__Shift__c> shiftsToRecalculate = new List<sirenum__Shift__c>();

        for (sirenum.SirenumEngine.Shift shift : shifts) {
            if (!shift.isExcluded && shift.isChecked) {
                shiftsToCheck.add(shift);
                // Clone the shift for recalculation to keep the original shift as is in order for the Sirenum Engine to link the alerts back to the correct shift
                shiftsToRecalculate.add(shift.shift.clone(true, true, true, true));
            }
        }

        Long now = System.currentTimeMillis();

        List<FormulaRecalcResult> results = Formula.recalculateFormulas(shiftsToRecalculate);

        // Report how long it took to recalculate formulas
        System.debug(LoggingLevel.INFO, String.format('Recalculating formulas for {0} shifts took {1} ms', new Object[]{
                shiftsToRecalculate.size(), System.currentTimeMillis() - now
        }));

        // Check for errors
        List<String> errors = new List<String>();

        for (FormulaRecalcResult result : results) {
            if (!result.isSuccess()) {
                for (FormulaRecalcFieldError fieldError : result.getErrors()) {
                    // Only check for errors to the IP_IntStudentWorkHoursRestriction__c field
                    if (fieldError.getFieldError() == 'IP_IntStudentWorkHoursRestriction') {
                        sirenum__Shift__c shift = (sirenum__Shift__c) result.getSObject();
                        String error = String.format('{0}/{1} - {2}', new String[] {
                                shift.sirenum__Contact__c,
                                shift.Id == null ? String.valueOf(shift.sirenum__Absolute_Start_Time__c) : shift.Id,
                                fieldError.getFieldError()
                        });
                        errors.add(error);
                    }
                }
            }
        }

        if (!errors.isEmpty()) {
            throw new WTRException('Failed to recalculate IP_IntStudentWorkHoursRestriction:\n' +
                    '  (Contact ID)/(Shift ID or Start Time) - Error\n  ' + String.join(errors, '\n  '));
        }

        // Store the recalculated formula field in finishDate (it is not used by the product) to discard the clones and free memory
        for (Integer i = 0; i < shiftsToCheck.size(); i++) {
            if (shiftsToRecalculate[i].IP_IntStudentWorkHoursRestriction__c?.isNumeric() == true) {
                shiftsToCheck[i].finishDate = Integer.valueOf(shiftsToRecalculate[i].IP_IntStudentWorkHoursRestriction__c);
            }
        }
    }

    /**
     * Split the shifts into timeline per contact (per evaluation group), only timelines with shifts to be evaluated
     * are returned
     *
     * @param shifts the list of shifts loaded by the SirenumEngine
     *
     * @return List of timelines with shifts to evaluate, each timeline is a list of shifts for a single contact (and evaluation group)
     */
    @TestVisible
    private static List<List<sirenum.SirenumEngine.Shift>> splitShiftsIntoTimelines(List<sirenum.SirenumEngine.Shift> shifts) {
        // The shifts per evaluation group and contact
        Map<Object[], List<sirenum.SirenumEngine.Shift>> shiftsByGroupAndContact =
                new Map<Object[], List<sirenum.SirenumEngine.Shift>>();

        // The timeline keys with shifts to evaluates
        Set<Object[]> timelineKeysToEvaluate = new Set<Object[]>();

        for (sirenum.SirenumEngine.Shift shift : shifts) {
            if (shift.isExcluded) {
                continue;
            }

            // Create a key with group and contact (the startDate is the evaluation group id)
            Object[] key = new Object[]{shift.startDate, shift.shift.sirenum__Contact__c};

            // Keep track of timeline keys with shifts that are to be evaluated
            if (isShiftRelevantForRule(shift)) {
                timelineKeysToEvaluate.add(key);
            }

            List<sirenum.SirenumEngine.Shift> shiftsList = shiftsByGroupAndContact.get(key);

            if (shiftsList == null) {
                shiftsList = new List<sirenum.SirenumEngine.Shift>();
                shiftsByGroupAndContact.put(key, shiftsList);
            }

            shiftsList.add(shift);
        }

        // Only retain the timelines with shifts to evaluate
        shiftsByGroupAndContact.keySet().retainAll(timelineKeysToEvaluate);

        // Return timelines to evaluate
        return shiftsByGroupAndContact.values();
    }

    /**
     * Evaluate the timeline and generate alerts for shifts that violate the rule
     *
     * @param timeline the timeline list of shifts to evaluate (not sorted)
     * @param alerts the list to add generated alerts into
     * @param weekEndingDay the week ending day to use
     */
    @TestVisible
    private static void evaluateTimeline(
            List<sirenum.SirenumEngine.Shift> timeline,
            List<sirenum__LogEntry__c> alerts,
            Integer weekEndingDay
    ) {
        // Sort the timeline chronologically
        timeline.sort();

        Datetime weekStart = Datetime.newInstance(0);
        Datetime weekEnd = Datetime.newInstance(0);
        Decimal totalWork = 0;

        for (sirenum.SirenumEngine.Shift shift : timeline) {
            // Start a new week if the shift starts after the week ends
            if (shift.startDT >= weekEnd) {
                weekStart = getWeekStart(shift.startDT, weekEndingDay);
                weekEnd = Datetime.newInstance(weekStart.date().addDays(7), ZERO_TIME);
                totalWork = 0;
            }

            // Add the shift work time to the weekly total
            totalWork += getEffectiveWork(shift, weekStart, weekEnd);

            // Check if the rule is violated (shift.finishDate hold the max hours per week)
            Boolean violated = isShiftRelevantForRule(shift) && totalWork > shift.finishDate;

            // Check if the shift goes over the end of the week
            if (shift.startDT < weekEnd && shift.finishDT > weekEnd) {
                // Start a new week with the work done in it from the shift
                weekStart = getWeekStart(shift.finishDT, weekEndingDay);
                weekEnd = Datetime.newInstance(weekStart.date().addDays(7), ZERO_TIME);
                totalWork = getEffectiveWork(shift, weekStart, weekEnd);

                // Recheck if the rule is violated in the new week
                violated |= isShiftRelevantForRule(shift) && totalWork > shift.finishDate;
            }

            if (violated) {
                // Create an alert for the shift
                alerts.add(new sirenum__LogEntry__c(
                        sirenum__Contact__c = shift.shift.sirenum__Contact__c,
                        sirenum__Shift__c = shift.shift.Id,
                        sirenum__Shift__r = shift.shift,
                        sirenum__Severity__c = 'Fatal',
                        sirenum__Category__c = 'International Student Weekly Hours',
                        sirenum__Details__c = String.format(
                                'International student exceeding {0} working hrs limit',
                                new Object[] { shift.finishDate }
                        )
                ));
            }
        }
    }

    /**
     * Get the start of the week at midnight for the provided value based on the week ending day.
     *
     * @param value the datetime value to get the start of week for
     * @param weekEndingDay the week ending day (0-Sun, 1-Mon, etc.)
     *
     * @return The start of the week at midnight for the provided value
     */
    @TestVisible
    private static Datetime getWeekStart(Datetime value, Integer weekEndingDay) {
        // Get diff in days to the end of the week
        Integer delta = weekEndingDay - sirenum.SirenumUtils.getDayNumber(value) + 1;

        // Make sure the result is negative
        if (delta > 0) {
            delta -= 7;
        }

        // Add days of the delta to get to the first day of the week at midnight
        return Datetime.newInstance(value.date().addDays(delta), ZERO_TIME);
    }

    /**
     * Indicate that the shift is relevant for the rule, that is, it is to be checked and IP_IntStudentWorkHoursRestriction__c
     * (stored in finishDate) have a numeric positive value
     *
     * @param shift the shift to check
     *
     * @return true when the shift is relevant for the rule
     */
    @TestVisible
    private static Boolean isShiftRelevantForRule(sirenum.SirenumEngine.Shift shift) {
        return shift.isChecked && shift.finishDate != null && shift.finishDate > 0;
    }

    /**
     * Get the effective work (in hours) within the provided time interval, excluding paid breaks
     *
     * @param shift the shift to get the effective work from
     * @param startTime the start of the interval
     * @param finishTime the finish of the interval
     *
     * @return effective work duration within the interval (in hours), excluding paid brakes
     */
    @TestVisible
    private static Decimal getEffectiveWork(sirenum.SirenumEngine.Shift shift, Datetime startTime, Datetime finishTime) {
        Datetime start = shift.startDT < startTime ? startTime : shift.startDT;
        Datetime finish = shift.finishDT > finishTime ? finishTime : shift.finishDT;

        // Calculate the time in hours (minus the paid breaks)
        Decimal effectiveLength = ((finish.getTime() - start.getTime()) / MILLISECONDS_PER_HOUR) - shift.paidBreakLength;

        // Ensure no negative work is return
        return Math.max(effectiveLength, 0);
    }
}