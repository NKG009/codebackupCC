                    {!sirenum__Placement__c.sirenum__Contact__r.MailingCity}<br></br>
                    {!sirenum__Placement__c.sirenum__Contact__r.MailingState}<br></br>
                    {!sirenum__Placement__c.sirenum__Contact__r.MailingCountry}
