<apex:page standardController="Contact" extensions="Payprofactivext" showHeader="false" sidebar="false" docType="html-5.0" standardStylesheets="true" pageStyle="Account">
    <apex:form id="form">
        <apex:pageMessages />
        <apex:pageBlock >
           
    <apex:pageBlockSection title="Please choose profile to activate" columns="1">
               <apex:pageBlockTable value="{!payprofile}" var="pay" id="table2" rendered="{!(payprofile.size !=0 )}" cellpadding="2" border="1" rowClasses="odd,even" styleClass="tableClass" width="100%">
                    <apex:column headervalue="Choose one" ><apex:inputCheckbox value="{!pay.selected}"  /></apex:column>
                    <apex:column value="{!pay.conp.Name}" />
                    <apex:column value="{!pay.conp.RecordType.name}" />
                    <apex:column value="{!pay.conp.IP_PrimaryPayMethod__c}" />
                </apex:pageBlockTable>  
            </apex:pageBlockSection>
            
             <p> &nbsp; </p>      
            <apex:pageBlockButtons >
                <apex:commandButton value="Activate" action="{!Finish}" />
                <apex:commandButton value="Close" action="{!closeme}" onclick="CloseARefresh();" />
            </apex:pageBlockButtons>
        </apex:pageBlock>
    </apex:form>
    
    <script>
    
    function CloseARefresh()
    {      
        window.opener.location.href="/{!$CurrentPage.parameters.id}";
        alert('Candiate Reinstated');
        self.close();
       
       
    }    
    </script>
</apex:page>