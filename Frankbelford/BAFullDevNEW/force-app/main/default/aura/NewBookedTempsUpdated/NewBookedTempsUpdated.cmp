<!-- NewBookedTempsUpdated -->
    <aura:component implements="forceCommunity:themeLayout,force:hasRecordId,lightning:isUrlAddressable" access="global" controller="NewBookedTempsComponentController">
   <ltng:require styles="{!join(',',
                          $Resource.assetsTest+'/assets/css/jquery-ui.css',
 						$Resource.webUI+'/assets/css/all.css',
                          $Resource.webUI+'/assets/css/fontawesome.css',
                          $Resource.webUI+'/assets/css/fontawesome.min.css',
                          $Resource.webUI+'/assets/css/dataTables.bootstrap.min.css',
                           
                          $Resource.webUI+'/assets/css/responsive.bootstrap.min.css',
                          $Resource.Tjcss2+'/assets/css/main.css',
                         $Resource.Tjcss2+'/assets/css/custom.css'
                          )
                          }" 
                  scripts="{!join(',',
                           $Resource.Tjcss2+'/assets/js/main.min.js',
                           $Resource.Tjcss2+'/assets/js/zoom.js',
                           $Resource.webUI+'/assets/js/custom.js'
                           )}"
                 afterScriptsLoaded="{!c.scriptsLoaded}"
                  />
    
    <ltng:require styles="{! $Resource.	DataTables + '/DataTables/media/css/jquery.dataTables.min.css'}" 
                   />   
       
    
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute type="boolean" name="checkparam" default="false" />
    <aura:attribute type="boolean" name="checkCompetencies" default="false" />
    <aura:attribute name="siteList" type="List" access="global"/>
    <aura:attribute name="candidateNameList" type="List" access="global"/>
    <aura:attribute name="selectedSite" type="String"/>
    <aura:attribute name="jobSiteList" type="List" access="global"/>
    <aura:attribute type="List" name="allshifts" />
    <aura:attribute type="List" name="shifts" />
    <aura:attribute name="selectedRating" type="Integer"/>
    <aura:attribute name="selectedjobrole" type="String"/>
    <aura:attribute name="Name" type="String"/>
    <aura:attribute type="Integer" name="pageNumber" default="1" />
    <aura:attribute type="Integer" name="maxPage" default="1" />
    <!--  <aura:handler name="change"	value="{!v.pageNumber}"	action="{!c.renderPage}" /> -->
    <aura:attribute name="listpage" type="List"  />
    <aura:attribute name="page" type="integer"/>
    <aura:attribute name="pages" type="integer"/>
    <aura:attribute name="total" type="integer"/>
    <aura:attribute type="List"    name="currentList" />
    <aura:attribute name="isOpenCancel" type="boolean" default="false"/>
    <aura:attribute name="CompetenciesList" type="List" access="global"/>
    <aura:attribute name="phoneNumber" type="string" access="global"/>
    <aura:attribute name="emailAdd" type="string" access="global"/>
    <aura:attribute name="userInfo" type="User" access="global"/>
    <aura:attribute name="defaultSiteID" type="String" access="global"/>
    <aura:attribute type="boolean" name="checkSearch" default="false"  access="global"/>
    <aura:attribute name="Spinner" type="boolean" default="false"/>		
     <aura:attribute name="site" type="String" /> 
    <head>
        <title>Impellam Project</title>
    </head>
    <body>		
        
        <div class="container-fluid" id="parentDivId">
            <!-- Compitencies Detail modal Popup -->
          <div class="custom-model modal fade" id="bookedTemp-popup" tabindex="-1" role="dialog" aria-labelledby="bookedTemp-popup">
			  	<div class="modal-dialog" role="document">
			    	<div class="modal-content">
			    		<button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
			    		<h1>Skills</h1>
                        <aura:if isTrue="{!v.checkCompetencies}">
			    		<h3>{!v.CompetenciesList[0].sirenum__Owner__r.Name}</h3>
                        <div class="ElementDetail__table">
							<table>
								<thead>
									<tr>
										<th>Competency Type</th>
										<th>Valid From</th>
										<th>Valid To</th>
									</tr>
								</thead>
								<tbody>
									  <aura:iteration items="{!v.CompetenciesList}" var="record" indexVar="idx">
                                        <tr>
                                           
                                            <td data-th="Competency Type">{!record.sirenum__TicketType__r.Name}</td>
                                            <aura:if isTrue="{!(record.sirenum__Valid_from__c != null)}">
                                                <td data-th="Valid From"><lightning:formattedDateTime value="{!record.sirenum__Valid_from__c}" year="numeric" month="numeric" day="numeric" /></td>
                                                <aura:set attribute="else">
                                                    <td data-th="Valid From">n/a</td>
                                                </aura:set>
                                            </aura:if>
                                            <aura:if isTrue="{!(record.sirenum__Valid_until__c != null)}">
                                                <td data-th="Valid To"><lightning:formattedDateTime value="{!record.sirenum__Valid_until__c}" year="numeric" month="numeric" day="numeric" /></td>
                                                <aura:set attribute="else">
                                                    <td data-th="Valid To">n/a</td>
                                                </aura:set>
                                            </aura:if>
                                        </tr>
                                    </aura:iteration> 
								</tbody>
							</table>
						</div>
                            <aura:set attribute="else">
                                <p class="cancel-text">No related skills to job role</p>
                            </aura:set>
                        </aura:if>
			    	</div>
			  	</div>
			</div>
            
            <!-- decline modal Popup -->
            <div class="custom-model modal fade" id="decline-popup" tabindex="-1" role="dialog" aria-labelledby="decline-popup">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="{!c.closeModelCancel}"><span aria-hidden="true">&times;</span></button>
                        <p class="cancel-text">Thank you for informing us that you wish to cancel the below shift</p><br></br>
                        <h3 class="contact-detail">A consultant will be in touch shortly.</h3>
                    </div>
                </div>
            </div>
            
            <nav class="headeNav">
                <div class="visible-xs mobile-nav">
                    <img src="{!$Resource.Tjcss + '/assets/img/mobile-nav.png'}" alt="Mobile Icon" title="Click to slide"/>
                </div>
                <a href="" class="logo" title="BlueArrow">
                    <img src="{!$Resource.Tjcss + '/assets/img/impellam-logo-blue.png'}" alt="Impellam Logo" Title="Impellam"/>
                </a>
                
                <ul class="headeNav__right">
                    <li>
                        <a href="" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                            <span class="hidden-xs hidden-sm">{!v.userInfo.Name}</span> 
                            <aura:if isTrue="{!v.userInfo.User_Image__c != null}">
                                <img src="{!v.userInfo.User_Image__c}" alt=""/>
                                <aura:set attribute="else">
                                    <img src="" class="imag" alt=""/>
                                </aura:set>
                            </aura:if>
                            <span class="caret"></span></a>
                        <ul class="dropdown-menu">
                            <li><a href="" onclick="{!c.myProfileNavigate}" title="My Profile">My Profile</a></li>
                            <li><a href="" onclick="{!c.siteManagementNavigate}" title="Setting">Site Management</a></li>
                            <li><a href="" onclick="{!c.logout}" title="Logout">Logout</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="col-sm-4 col-md-3 headeNav__selectpicker">
                    <!--<div class="btn-group bootstrap-select">--> 
                     <ui:inputSelect aura:id="siteId" class="slselect" label="Site Name" change="{! c.siteChanged }">
                     <aura:iteration items="{!v.siteList}" var="item" >
                            <option text="{!item.label}" value="{!item.value}" selected="{!item.selected}"  />
         </aura:iteration>
                    </ui:inputSelect>
                   
                    <!--</div>-->
                </div> 
            </nav>
            <div class="timesheet-section">
            <c:BlueBarComp site="{!v.site}" ></c:BlueBarComp>  
                
                <div class="timesheet-section__right-part">
                    <ol class="breadcrumb">
                        <li><a href="javascript:void(0)" onclick="{!c.dashboardnavigate}" title="Dashboard">Dashboard</a></li>
                        <li><!--<a href="" title="Dashboard">-->My Temps<!--</a>--></li>
                        <li class="active">Booked Temps</li>
                    </ol>
                    <div class="search-section">
                        <form class="row">
                            <div class="col-sm-6 col-md-5 col-lg-4">
                                <label class="global-label">Temps Name</label>
                                <lightning:select label="" aura:id="candidateId" name="candidateSelect"  tabindex = "-98">
                                    <aura:iteration items="{!v.candidateNameList}" var="item">
                                        <option text="{!item.label}" value="{!item.value}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                            <div class="col-sm-6 col-md-3 col-lg-2">
                                <label class="global-label">Job Role</label>
                                <lightning:select name="jobRoleSelect" label="" aura:id="jobRoleId"  tabindex = "-98">
                                    <aura:iteration items="{!v.jobSiteList}" var="item">
                                        <option text="{!item.label}" value="{!item.value}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                            <div class="col-sm-6 col-md-4 col-lg-3">
                                <label class="global-label">Date</label>
                                <input type="text" style="margin-top: 3px;"  class="global-input" name="Date" id="timePeriod" placeholder="Select Date" onclick="{!c.handleOnClick}"
                                       onkeypress="{!c.handleKeyPress}" onmouseover="{!c.handleMouseEnter}" onmouseout="{!c.handleMouseLeave}"/>
                            </div>
                            
                            <div class="col-sm-6 col-md-4 col-lg-3">
                                <lightning:button label="Search" title="Search" class="search-btn" onclick="{!c.searchShifts}" />&nbsp;
                                <!--<input type="submit" class="search-btn" name="Search" value="Search" onclick="{!c.searchShifts}"/>-->
                                <input type="reset" class="clearAll-btn" name="Clear" onclick="{!c.resetAllValues}" value="Clear All"/>
                            </div>
                        </form>
                        <!-- calendar starts -->
                        <section class="calendar-pop">
                            <div class="calendar">
                                <div class="control-bar">
                                    <ul>
                                        <li id="today"><a href="">Today</a></li>
                                        <li id="tomorrow"><a href="">Tomorrow</a></li>
                                        <li id="nextweek"><a href="">Next 7 days</a></li>
                                        <li id="nextmonth"><a href="">Next 30 days</a></li>
                                        <li id="nexttwomonth"><a href="">Next 60 days</a></li>
                                    </ul>
                                </div>
                                <div id="datepicker"></div>
                            </div>
                        </section>
                        <!-- calendar ends -->
                    </div>
                    
                     <!--export-->
                       <lightning:button variant="brand" class="exportButton" label="Export" title="Export" onclick="{!c.downloadCsv}" />
                        <!--export-->
                    
                    <div class="searchDetail-section">
                        <aura:if isTrue="{!v.checkparam}">
                            <table id="tableId" class="slds-no-row-hover slds-table slds-table_bordered slds-table_cell-buffer" cellspacing="0" width="100%">
                                
                                <thead>
                                    <tr>
                                        <th>Job Role</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                        <th>Requirement</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                            <aura:set attribute="else">
                                <table id="tableId" class="searchDetail_table book-temp-table" cellspacing="0" width="100%">
                                     <div id="overlay">
                                        <img src="{!$Resource.Loadingimage}"  width="120" height="100" alt=""/>
                                   </div> 
                                    <thead>
                                        <tr>
                                            <th class="centeralign">Temp Name</th>
                                            <th class="centeralign">Job Role</th>
                                            <th class="centeralign">Start Date</th>
                                            <th class="centeralign">End Date</th>
                                            <th class="centeralign">Start Time</th>
                                            <th class="centeralign">End Time</th>
                                            <th class="">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items="{!v.shifts}" var="record" indexVar="idx">
                                            <tr>
                                                <td class="centeralign ">{!record.sirenum__Contact__r.Name}</td>
                                                <td class="centeralign">{!record.sirenum__Team__r.Name}</td>
                                                <td class="centeralign"><!--<span class='hide'>{!record.Scheduled_Start_Date_Text__c}</span>--><lightning:formattedDateTime value="{!record.sirenum__Scheduled_Start_Time__c}" year="numeric" month="numeric" day="numeric" /></td>
                                                <td class="centeralign"><!--<span class='hide'>{!record.Scheduled_End_Date_Text__c}</span>--><lightning:formattedDateTime value="{!record.sirenum__Scheduled_End_Time__c}" year="numeric" month="numeric" day="numeric" /></td>
                                               <td class="centeralign">{!record.Starttime__c}</td>
                                           <td class="centeralign">{!record.EndTime__c}</td>         <td>
                                                    <span class="edit_action popup-btn" data-toggle="modal" Id="{!record.Id}" data-target="#bookedTemp-popup" onclick="{!c.CompetenciesDetails}">Details</span>
                                                    <span class="action-button decline" data-toggle="modal" data-target="#decline-popup" Id="{!record.Id}" onclick="{!c.Reject}">Cancel</span>
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </aura:set>
                        </aura:if>  
                    </div>
                    <!--		<div style="text-align:right;margin-top:-50px;"> 
                        <c:TestPagination currentPageNumber="{!v.pageNumber}" 
                                    maxPageNumber="{!v.maxPage}" listpage="{!v.listpage}" /> 
                    </div>	-->	
                    
                    <footer>
                        <div class="row">
                            <div class="col-sm-6"><p> &copy; Blue Arrow, All rights reserved 2019.</p></div>
                            <div class="col-sm-6"><p>Regd Address:  800 The Boulevard, Capability Green, Luton, Bedfordshire, LU1 3BA. Company No. 00641659</p></div>
                        </div>
                    </footer>
                </div>
                
            </div>
        </div>
        <div class="sidenav-overlay"></div>
        <div class="search-overlay"></div>		
    </body>
</aura:component>