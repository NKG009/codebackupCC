<aura:component Controller="MyShiftController" implements="forceCommunity:availableForAllPageTypes,force:hasRecordId,force:appHostable,flexipage:availableForRecordHome,force:lightningQuickAction" access="global" >
    
    <!--pageload Shift starts-->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <!--pageload Shift ends-->
    
    <!-- feedback atrributes start-->
     <aura:attribute name="isOpenCancel" type="boolean" default="false"/>
      <aura:attribute type="Integer" name="selectedRating"/>
    <aura:attribute type="Integer" name="storeRating"/>
     <aura:attribute name="feedbackshift" type="String"  />
   
    <!-- feedback atrributes end-->
    
    <!--listing Shift start-->
    <aura:attribute type="List"    name="allshifts" />
    <aura:attribute type="List"    name="currentList" />
    <!--listing Shift end-->
   <aura:attribute type="Boolean" name="hyperclick1" default="false"/>
    <aura:attribute type="Boolean" name="hyperclick2" default="false"/>
    <aura:attribute type="Boolean" name="hyperclick3" default="false"/>
    <aura:attribute type="Boolean" name="hyperclick4" default="false"/>
    <!--Pagination Shift start -->
    <aura:attribute type="Integer" name="pageNumber" default="1" />
    <aura:attribute type="Integer" name="maxPage" default="1" />
    <aura:handler name="change"	value="{!v.pageNumber}"	action="{!c.renderPage}" />
    <!-- Pagination Shift end-->
    
 <div class="slds-scrollable slds-wrap">  
     <aura:if isTrue="{!v.hyperclick1}"> 
         
    <a href="javascript:void(0)" style="color:red;" name="Today" onclick="{!c.getList1}">Today</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
     <aura:set attribute="else">
       <a href="javascript:void(0)" name="Today" onclick="{!c.getList1}">Today</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
   
    </aura:set>
    </aura:if>  
  <aura:if isTrue="{!v.hyperclick2}">   
    <a href="javascript:void(0)" style="color:red;" name="Yesterday" onclick="{!c.getList2}">Yesterday</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
   <aura:set attribute="else">
   <a href="javascript:void(0)" name="Yesterday" onclick="{!c.getList2}">Yesterday</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
        
    </aura:set>
    </aura:if>  
     <aura:if isTrue="{!v.hyperclick3}">  
       <a href="javascript:void(0)" style="color:red;" name="Last_7_days" onclick="{!c.getList3}">Last 7 Days</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      <aura:set attribute="else">
        <a href="javascript:void(0)" name="Last_7_days" onclick="{!c.getList3}">Last 7 Days</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
     </aura:set>
    </aura:if>      
  
    <aura:if isTrue="{!v.hyperclick4}"> 
    <a href="javascript:void(0)" style="color:red;" name="Last_30_days" onclick="{!c.getList4}">Last 30 Days</a>

    <aura:set attribute="else">
         <a href="javascript:void(0)" name="Last_30_days" onclick="{!c.getList4}">Last 30 Days</a>
   
      </aura:set>
    </aura:if> 
    </div>
<br></br>
   <div class="slds-scrollable slds-wrap">   
    <table class="slds-no-row-hover slds-table slds-table--bordered slds-table--cell-buffer slds-table--fixed-layout">
        <thead>
            <tr >
                <th class="headingfont" scope="col" style="text-align:center;width:180px;"><div  title="Created Date">Start Date</div></th>
                <th class="headingfont" scope="col" style="text-align:center;width:350px;"><div class="slds-truncate" title="Job Role">Job Role</div></th>
                <th class="headingfont" scope="col" style="text-align:center;width:300px;"><div class="slds-truncate" title="Site">Site</div></th>
                <th class="headingfont" scope="col" style="text-align:center;width:110px;"><div class="slds-truncate" title="Start Time">Start Time</div></th>
                <th class="headingfont" scope="col" style="text-align:center;width:110px;"><div class="slds-truncate" title="End Time">End Time</div></th>
                <th class="headingfont" scope="col" style="text-align:center;width:110px;"><div class="slds-truncate" title="Action">Action</div></th>
 				<th class="headingfont" scope="col" style="text-align:center;width:110px;"><div class="slds-truncate" title="Rating">Rating</div></th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration items="{!v.currentList}" var="record" indexVar="idx">
                <tr >
                   <td style="text-align:center;" ><div class="slds-truncate"><lightning:formattedDateTime value="{!record.sirenum__Scheduled_Start_Time__c}" year="numeric" month="numeric" day="numeric" /></div></td>
                    <td style="text-align:center;"><div class="slds-truncate slds-grow slds-cell-wrap">{!record.sirenum__Team__r.Name}</div></td>
                    <td style="text-align:center;"><div class="slds-truncate slds-grow slds-cell-wrap">{!record.sirenum__Site__r.Name}</div></td>
                    <td style="text-align:center;"><div class="slds-truncate"><lightning:formattedDateTime hour12="false" hour="2-digit" minute="2-digit" value="{!record.sirenum__Scheduled_Start_Time__c}" /></div></td>
                    <td style="text-align:center;"><div class="slds-truncate"><lightning:formattedDateTime hour12="false" hour="2-digit" minute="2-digit" value="{!record.sirenum__Scheduled_End_Time__c}" /></div></td>
                    
                                   
                    <td style="text-align:center;"><aura:if isTrue="{!record.RankingStored__c==null}">
                        <div  style="text-align:center;">
                       <lightning:button label="Feedback" class="Feedbackbutton" variant="Brand" onclick="{!c.feedback}" value="{!record.Id}"  />
                       
                        </div>
                        <aura:set attribute="else">
                         <div   style="text-align:center;">
                       <lightning:button label="Feedback" disabled="true" variant="Brand" onclick="{!c.feedback}" value="{!record.Id}"  />
                       
                        </div>
                        </aura:set>
                        </aura:if>
                        </td>
  <td style="text-align:center;">
        <aura:if isTrue="{!record.RankingStored__c=='0'}">
        <img src="{!$Resource.Ratings+'/nostar.png'}" style="height:20px;width:90px;"/>    
      </aura:if>
      <aura:if isTrue="{!record.RankingStored__c==null}">
        <img src="{!$Resource.Ratings+'/nostar.png'}" style="height:20px;width:90px;"/>    
      </aura:if>
    <aura:if isTrue="{!record.RankingStored__c=='1'}">  
         <img src="{!$Resource.Ratings+'/1star.png'}" style="height:20px;width:90px;"/> 
      </aura:if>  
    <aura:if isTrue="{!record.RankingStored__c=='2'}">
           <img src="{!$Resource.Ratings+'/2star.png'}" style="height:20px;width:90px;"/> 
          </aura:if> 
       <aura:if isTrue="{!record.RankingStored__c=='3'}">
           <img src="{!$Resource.Ratings+'/3star.png'}" style="height:20px;width:90px;"/> 
          </aura:if> 
       <aura:if isTrue="{!record.RankingStored__c=='4'}">
           <img src="{!$Resource.Ratings+'/4star.png'}" style="height:20px;width:90px;"/> 
          </aura:if> 
       <aura:if isTrue="{!record.RankingStored__c=='5'}">
           <img src="{!$Resource.Ratings+'/5star.png'}" style="height:20px;width:90px;"/> 
          </aura:if> 
                       
                    
                    </td>

                </tr>
            </aura:iteration>    
        </tbody>
       </table> </div><br></br>
        <div style="text-align:right;"> <c:PaginationButton currentPageNumber="{!v.pageNumber}" 
                                    maxPageNumber="{!v.maxPage}" /> </div>
    <div class="slds-truncate" style="text-align:Left;">
                       <lightning:button label="Back" class="Backbutton" variant="Brand" onclick="{!c.getBackscreen}"   />
                       
                        </div>
           <aura:if isTrue="{!v.isOpenCancel}">
        <div role="dialog" tabindex="-1" aria-labelledby="header99" class="slds-modal slds-fade-in-open slds-scrollable slds-wrap">
            <div class="slds-modal__container slds-scrollable slds-wrap">
                <form>
                    <div class="slds-modal__header" style="width:550px;">
                       How likely are you to recommend this shift at this client site?
                        <br/>
                        <br/>
                        Please provide a Star rating for this Shift
                        <button class="slds-button slds-modal__close slds-button--icon-inverse" title="Close" onclick="{!c.closeModelCancel}">
                            X
                            <span class="slds-assistive-text">Close</span>
                        </button>
                    </div>
                    <div class="slds-modal__content slds-p-around--medium " style="width:550px;height:300px;top:50px;">
                        <lightning:layout horizontalAlign="spread">
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="0" label="0" onclick="{! c.selectRating }" />
                            </lightning:layoutItem>  
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="1" label="1" onclick="{! c.selectRating }" />
                            </lightning:layoutItem>
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="2" label="2" onclick="{! c.selectRating }" />
                            </lightning:layoutItem> 
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="3" label="3" onclick="{! c.selectRating }" />
                            </lightning:layoutItem> 
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="4" label="4" onclick="{! c.selectRating }" />
                            </lightning:layoutItem> 
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="rating" variant="brand" class="Starbutton" value="5" label="5" onclick="{! c.selectRating }" />
                            </lightning:layoutItem> 
                        </lightning:layout> 
                        <br/><br/><br/><br/><br/><br/><br/><br/><br/>
                        <lightning:layout horizontalAlign="spread">
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="Back" class="Backbutton" variant="brand" value="Back" label="Back" onclick="{! c.closeModelCancel }" />
                            </lightning:layoutItem>  
                            <lightning:layoutItem padding="horizontal-small">
                                <lightning:button aura:id="submitRating" class="Feedbackbutton" variant="brand" value="submitRating" label="Submit" onclick="{!c.submitRating}" />
                            </lightning:layoutItem>
                        </lightning:layout>
                    </div>
                </form>
            </div>
        </div>
        <div class="slds-backdrop slds-backdrop--open"></div>
    </aura:if>
    
</aura:component>