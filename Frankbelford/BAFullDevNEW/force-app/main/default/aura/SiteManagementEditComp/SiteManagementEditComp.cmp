<!--SiteManagemnetEditComp-->
<aura:component implements="forceCommunity:themeLayout,force:hasRecordId,lightning:isUrlAddressable" access="global" 
                controller="SiteManagementComponentController">
    <ltng:require styles="{!join(',',
                          $Resource.webUI+'/assets/css/all.css',
                          $Resource.webUI+'/assets/css/fontawesome.css',
                          $Resource.webUI+'/assets/css/fontawesome.min.css',
                          $Resource.webUI+'/assets/css/custom.css',
                          $Resource.Tjcss2+'/assets/css/main.css',
                          $Resource.Tjcss+'/assets/css/dataTables.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery.dataTables.min.css',
                          $Resource.Tjcss+'/assets/css/responsive.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery-ui.css'
                          )
                          }"
                  scripts="{!join(',',
                           $Resource.Tjcss+'/assets/js/main.min.js',
                           $Resource.webUI+'/assets/js/custom.js'
                           )}"
                  />
    <!-- attributes -->
    <aura:attribute name="Name" type="String"/>
    <aura:attribute name="siteList" type="List" access="global"/>
    <aura:attribute name="siteListtoDisplay" type="List" access="global"/>
    <aura:attribute name="SiteInfo" type="sirenum__Site__c" access="global"/>
    <aura:attribute name="userInfo" type="User" access="global"/>
    <aura:attribute name="siteSelected" type="User" access="global"/>
    <aura:attribute name="selectedValue" type="String" access="global"/>
    <aura:attribute name="displayPopup" type="boolean" access="global" default="false"/>
    	  <aura:attribute name="site" type="String" /> 
    <!-- handler -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <title>Impellam Project</title>
    	
    <body>
       
       <div class="container-fluid"> 
           
      
            <nav class="headeNav">
                <div class="visible-xs mobile-nav">
                    <img src="{!$Resource.Tjcss + '/assets/img/mobile-nav.png'}" alt="Mobile Icon" title="Click to slide"/>
                </div>
                <a href="" class="logo" title="BlueArrow">
                    <img src="{!$Resource.Tjcss + '/assets/img/impellam-logo-blue.png'}" alt="Impellam Logo" Title="Impellam"/>
                </a>
                
                <ul class="headeNav__right">
                    <li>
                        <a href="" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                            <span class="hidden-xs hidden-sm">{!v.userInfo.Name}</span> 
                            <aura:if isTrue="{!v.userInfo.User_Image__c != null}">
                                <img src="{!v.userInfo.User_Image__c}" alt=""/>
                                <aura:set attribute="else">
                                    <img src="" class="imag" alt=""/>
                                </aura:set> 
                            </aura:if>
                            <span class="caret"></span></a>
                        <ul class="dropdown-menu">
                            <li><a href="" onclick="{!c.myProfileNavigate}" title="My Profile">My Profile</a></li>
			            	<li><a href="" onclick="{!c.siteManagementNavigate}" title="Setting">Site Management</a></li>
			            	<li><a href="" onclick="{!c.logout}" title="Logout">Logout</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="col-sm-4 col-md-3 headeNav__selectpicker">
                    <ui:inputSelect aura:id="siteId" class="slselect" label="Site Name" change="{! c.siteChanged }">
                     <aura:iteration items="{!v.siteList}" var="item" >
                             <option text="{!item.label}" value="{!item.value}" />
         </aura:iteration>
                    </ui:inputSelect>     
                  
                </div>
            </nav>
            <div class="timesheet-section">
                
              <c:BlueBarComp site="{!v.site}" ></c:BlueBarComp>  
                
                <div class="timesheet-section__right-part">
                    <ol class="breadcrumb">
                        <li><a href="javascript:void(0)" onclick="{!c.dashboardnavigate}" title="Dashboard">Dashboard</a></li>
                        <li class="active">Site Management</li>
                    </ol>
                    <div class="search-section vacancies-section">
                        <div class="address-details">
                            <form class="row">
                                <div class="col-sm-12">
                                    <h2>Site Address:</h2>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">Address Lines</label>
                                    <!--<input type="text" class="global-input" name="Street" value="{!v.SiteInfo.sirenum__Street_Address__c}" placeholder="Street" id="streetId"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.sirenum__Street_Address__c}" placeholder="Address Lines" aura:id="streetId"  disabled="true"/>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">City</label>
                                    <!--<input type="text" class="global-input" name="City" value="{!v.SiteInfo.sirenum__City__c}" placeholder="City" id="cityId"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.sirenum__City__c}" placeholder="City" aura:id="cityId" disabled="true"/>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">County</label>
                                    <!--<input type="text" class="global-input" name="State" value="{!v.SiteInfo.sirenum__State__c}" placeholder="State" id="state"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.sirenum__State__c}" placeholder="County" aura:id="stateId" disabled="true"/>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">Country</label>
                                    <!--<input type="text" class="global-input" name="Country" value="{!v.SiteInfo.sirenum__Country__c}" placeholder="Country" id="countryId"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.sirenum__Country__c}" placeholder="Country" aura:id="countryId" disabled="true"/>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">Postcode</label>
                                    <!--<input type="text" class="global-input" name="Postcode" value="{!v.SiteInfo.sirenum__Postal_Code__c}" placeholder="Postcode" id="postalcodeId"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.sirenum__Postal_Code__c}" placeholder="Postcode" aura:id="postalcodeId" disabled="true"/>
                                </div>
                                
                            </form>    
                            <form class="row">
                                <div class="col-sm-12">
                                    <hr></hr>
                                </div>
                                <div class="col-sm-12">
                                    <h2>Main Contact:</h2>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">First Name</label>
                                    <!--<input type="text" class="global-input" name="First Name" value="{!v.SiteInfo.IP_MainContact__r.FirstName}" placeholder="First Name" id="mainContactFirstNameId"/>-->
                                    <ui:inputText class="global-input"  value="{!v.SiteInfo.IP_MainContact__r.FirstName}" placeholder="First Name" aura:id="mainContactFirstNameId"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Last Name</label>
                                    <!--<input type="text" class="global-input" name="Last Name" value="{!v.SiteInfo.IP_MainContact__r.LastName}"  placeholder="Last Name" id="mainContactLastNameId"/>-->
									<ui:inputText class="global-input"  value="{!v.SiteInfo.IP_MainContact__r.LastName}" placeholder="Last Name" aura:id="mainContactLastNameId"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Email</label>
                                     <!--<input type="email" class="global-input" name="Email" value="{!v.SiteInfo.IP_MainContact__r.Email}" placeholder="Email" id="mainContactEmailId"/>-->
									<ui:inputText class="global-input"  value="{!v.SiteInfo.IP_MainContact__r.Email}" placeholder="Email" aura:id="mainContactEmailId"/>
                                </div>
                                <div class="col-sm-12">
                                    <hr></hr>
                                </div>
                               <!-- <div class="col-sm-12">
                                    <h2>Secondary Approver:</h2>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">First Name</label>
									<ui:inputText class="global-input"  value="{!v.SiteInfo.IP_InvoiceContact__r.FirstName}" placeholder="First Name" aura:id="secAppFirstNameID"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Last Name</label>                                    
									<ui:inputText class="global-input"  value="{!v.SiteInfo.IP_InvoiceContact__r.LastName}" placeholder="Last Name" aura:id="secAppLastNameID"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Email</label>                                    
									<ui:inputText class="global-input"  value="{!v.SiteInfo.IP_InvoiceContact__r.Email}" placeholder="Email" aura:id="secAppEmailID"/>
                                </div>
                                <div class="col-sm-12">
                                    <hr></hr>
                                </div>-->
                                <div class="col-sm-12">
                                    <h2>Escalation Contact:</h2>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">First Name</label>
                                    <!--<input type="text" class="global-input" name="FirstName" value="{!v.SiteInfo.Emergency_Contact__r.FirstName}" placeholder="First Name" id="escConFirstNameId"/>-->
									<ui:inputText class="global-input"  value="{!v.SiteInfo.Emergency_Contact__r.FirstName}" placeholder="First Name" aura:id="emgConFirstNameId"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Last Name</label>
                                    <!--<input type="text" class="global-input" name="LastName" value="{!v.SiteInfo.Emergency_Contact__r.LastName}" placeholder="Last Name" id="escConLastNameId"/>-->
									<ui:inputText class="global-input"  value="{!v.SiteInfo.Emergency_Contact__r.LastName}" placeholder="Last Name" aura:id="emgConLastNameId"/>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Email</label>
                                    <!--<input type="email" class="global-input" name="Email" value="{!v.SiteInfo.Emergency_Contact__r.Email}" placeholder="Email" id="escConFirstNameId"/>-->
									<ui:inputText class="global-input"  value="{!v.SiteInfo.Emergency_Contact__r.Email}" placeholder="Email" aura:id="emgConEmailId"/>
                                </div>
                                <div class="col-sm-12">
                                    <hr></hr>
                                </div>
                                <div class="col-sm-12 text-right">
                            		<span class="edit_action popup-btn" data-toggle="modal" data-target="#bookedTemp-popup" id="updateSitebtnId" >
										<!--<button type="submit" class="action-button accept" onclick="{!c.updateSite}">Submit</button>-->
                                        <lightning:button value="submit" label="Submit" onclick="{!c.updateSite}"  class="action-button accept"/>
                                    </span>
                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                    <!--<lightning:button value="submit" label="submit" onclick="{!c.updateSite}" class="action-button accept"/>-->
                                    
                                    <lightning:button label="Close" onclick="{!c.goback}" class="action-button edit" variant="Brand"/>
                                    
                                    <button type="reset" class="action-button decline">Clear</button>
                                    
                                </div> 
                            </form>
                        </div>
                    </div>
                    <footer>
                        <div class="row">
                            <div class="col-sm-6"><p> &copy; Blue Arrow, All rights reserved 2019.</p></div>
                            <div class="col-sm-6"><p>Regd Address:  800 The Boulevard, Capability Green, Luton, Bedfordshire, LU1 3BA. Company No. 00641659</p></div>
                        </div>
                    </footer>
                </div>
            </div>
        </div>
        <div class="sidenav-overlay"></div>
        <div class="search-overlay"></div>
    </body>
</aura:component>