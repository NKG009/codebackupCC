    <formulas>
        <name>CandidateNameAndComma</name>
        <dataType>String</dataType>
        <expression>{!LoopThroughLongLists.TKC_Candidate_Name__c}&amp; &apos;, &apos;</expression>
    </formulas>
    <formulas>
        <name>FurtherCandidateIds</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds})=18, &apos;&apos;,
IF(LEN({!CandidateIds})&gt;18,
TRIM(RIGHT({!CandidateIds}, LEN({!CandidateIds}) - FIND(&quot;,&quot;,{!CandidateIds}))),null))</expression>
    </formulas>
    <formulas>
        <name>GetNextCandidateId</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds}) =18, {!CandidateIds},
IF(LEN({!CandidateIds}) &gt;18,
LEFT({!CandidateIds}, FIND(&quot;,&quot;,{!CandidateIds}) - 1),null))</expression>
    </formulas>
    <formulas>
        <name>NotAddedCandidatesFinal</name>
        <dataType>String</dataType>
        <expression>LEFT( {!NotAddedCandidateNames}, LEN({!NotAddedCandidateNames})- 2)</expression>
    </formulas>
    <formulas>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Flow.FaultMessage}),

IF(ISBLANK({!NotAddedCandidateNames}), 
TEXT({!NumberOfLongListsCreated}) &amp; &apos; &apos; &amp; {!$Label.TKC_CandidatesAddedToLongList} &amp; &apos; &apos; &amp; {!GetJob.Name},

TEXT({!NumberOfLongListsCreated}) &amp; &apos; &apos; &amp; {!$Label.TKC_CandidatesAddedToLongList} &amp; &apos; &apos;  &amp; {!GetJob.Name} &amp; &apos;. &apos; &amp;
{!$Label.TKC_CandidatesNotAddedtoLongList} &amp; &apos; &apos; &amp; {!NotAddedCandidateNames}
)

,{!$Label.TKC_ErrorMessage})</expression>
    </formulas>
    <formulas>
        <name>SelectedIdsLength</name>
        <dataType>Number</dataType>
        <expression>LEN({!CandidateIds})</expression>
        <scale>2</scale>
    </formulas>
