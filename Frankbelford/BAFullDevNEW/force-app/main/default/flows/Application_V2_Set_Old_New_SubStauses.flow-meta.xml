<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <formulas>
        <name>NewStageSubStatus</name>
        <dataType>String</dataType>
        <expression>Text({!$Record.TR1__Stage__c}) &amp; &quot;: &quot;&amp;
text({!$Record.Substatus__c})</expression>
    </formulas>
    <formulas>
        <name>OldStageSubstatus</name>
        <dataType>String</dataType>
        <expression>Text({!$Record__Prior.TR1__Stage__c}) &amp; &quot;: &quot;&amp;
text({!$Record__Prior.Substatus__c})</expression>
    </formulas>
    <interviewLabel>Application V2 &gt; Set Old New SubStauses {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Application V2 &gt; Set Old New SubStauses</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Most_Recent_History</name>
        <label>Get Most Recent History</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Update_Application_History</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>TR1__Application__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>TR1__Application_History__c</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Application_History</name>
        <label>Update Application History</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Most_Recent_History.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>New_Stage_SubStatus__c</field>
            <value>
                <elementReference>NewStageSubStatus</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Old_Stage_SubStatus__c</field>
            <value>
                <elementReference>OldStageSubstatus</elementReference>
            </value>
        </inputAssignments>
        <object>TR1__Application_History__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Prior_Stages</name>
        <label>Update Prior Stages</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Most_Recent_History</targetReference>
        </connector>
        <inputAssignments>
            <field>Prior_Stage__c</field>
            <value>
                <elementReference>$Record__Prior.TR1__Stage__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Prior_Substatus__c</field>
            <value>
                <elementReference>$Record__Prior.Substatus__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Prior_Stages</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>TR1__Stage__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Substatus__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>TR1__Application_V2__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
