            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Account_Holder</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>Get_Pay_Profile.IP_BankAccountName__c</elementReference>
            </defaultValue>
            <fieldText>Account Holder</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Account Holder should not exceed 30 characters&lt;/p&gt;</errorMessage>
                <formulaExpression>LEN({!Account_Holder})&lt;30</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Account_Number</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>Get_Pay_Profile.IP_Account_Number__c</elementReference>
            </defaultValue>
            <fieldText>Account Number</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Account Number must be 8 digits with no spaces&lt;/p&gt;</errorMessage>
                <formulaExpression>REGEX({!Account_Number}, &quot;[0-9]{8}&quot;)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Sort_Code</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>Get_Pay_Profile.IP_Sort_Code__c</elementReference>
            </defaultValue>
            <fieldText>Sort Code</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Sort Code must be 6 digits with no spaces&lt;/p&gt;</errorMessage>
                <formulaExpression>REGEX({!Sort_Code}, &quot;[0-9]{6}&quot;)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Building_Society_Roll_No</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>Get_Candidate.sirenum__Payment_Building_Society_Number__c</elementReference>
            </defaultValue>
            <fieldText>Building Society Roll No</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Building Society Number should be alphanumeric with a minimum of 1 number, no special characters and under 20 characters long.&lt;/p&gt;</errorMessage>
                <formulaExpression>AND(Len({!Building_Society_Roll_No})&lt;20,REGEX({!Building_Society_Roll_No},&quot;(?=.*[0-9])([a-zA-Z0-9+-/]+)&quot;))</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
