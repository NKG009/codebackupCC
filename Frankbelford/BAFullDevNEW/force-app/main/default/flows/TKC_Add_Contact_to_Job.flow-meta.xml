    <formulas>
        <name>CreatedApplicationCandidatesComma</name>
        <dataType>String</dataType>
        <expression>{!LoopThroughCandidateIds} &amp; &apos;, &apos;</expression>
    </formulas>
    <formulas>
        <name>FurtherCandidateIds</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds})=18, &apos;&apos;,
IF(LEN({!CandidateIds})&gt;18,
TRIM(RIGHT({!CandidateIds}, LEN({!CandidateIds}) - FIND(&quot;,&quot;,{!CandidateIds}))),null))</expression>
    </formulas>
    <formulas>
        <name>GetNextCandidateId</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds}) =18, {!CandidateIds},
IF(LEN({!CandidateIds}) &gt;18,
LEFT({!CandidateIds}, FIND(&quot;,&quot;,{!CandidateIds}) - 1),null))</expression>
    </formulas>
    <formulas>
        <name>NoApplicationCreatedCandidateNamesComma</name>
        <dataType>String</dataType>
        <expression>{!LoopThoughApplications.TKC_Applicant_Name__c} &amp; &apos;, &apos;</expression>
    </formulas>
    <formulas>
        <name>NoApplicationCreatedCandidateNamesFinal</name>
        <dataType>String</dataType>
        <expression>LEFT( {!NoApplicationCreatedCandidateNames}, LEN({!NoApplicationCreatedCandidateNames})- 2)</expression>
    </formulas>
    <formulas>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Flow.FaultMessage}),

IF(ISBLANK({!NoApplicationCreatedCandidateNames}), 
TEXT({!NumberOfApplicationsCreated}) &amp;&quot; &quot; &amp; {!$Label.TKC_CandidatesAddedToJob} &amp; &apos; &apos; &amp; {!GetJob.Name},

TEXT({!NumberOfApplicationsCreated}) &amp; &apos; &apos; &amp; {!$Label.TKC_CandidatesAddedToJob} &amp; &apos; &apos; &amp; {!GetJob.Name} &amp; &apos;. &apos; &amp;
{!$Label.TKC_CandidatesNotAddedtoJob} &amp; &apos; &apos; &amp; {!NoApplicationCreatedCandidateNames}
)

,{!$Label.TKC_ErrorMessage})</expression>
    </formulas>
    <formulas>
