    <formulas>
        <name>CheckrequiredfieldsFormula</name>
        <dataType>Boolean</dataType>
        <expression>AND(ISNEW(),
NOT(ISBLANK({!$Record.Name__c} )),
NOT(ISBLANK({!$Record.Email})),
NOT(ISBLANK({!$Record.IP_TempestID__c})),
NOT(ISBLANK(TEXT({!$Record.IP_TempestDivision__c}))),
NOT(ISBLANK(TEXT({!$Record.IP_TempestDepartment__c})))
)</expression>
    </formulas>
    <formulas>
        <name>ReflagconsultantFormula</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISNEW()),
NOT(ISBLANK({!$Record.Name__c} )),
NOT(ISBLANK({!$Record.Email})),
NOT(ISBLANK({!$Record.IP_TempestID__c})),
NOT(ISBLANK(TEXT({!$Record.IP_TempestDivision__c}))),
NOT(ISBLANK(TEXT({!$Record.IP_TempestDepartment__c}))),
(
ISCHANGED({!$Record.Name__c} )||
ISCHANGED({!$Record.Email} )||
ISCHANGED({!$Record.IP_TempestID__c} )||
ISCHANGED({!$Record.IP_TempestDivision__c} )||
ISCHANGED({!$Record.IP_TempestDepartment__c} )
)
)</expression>
    </formulas>
