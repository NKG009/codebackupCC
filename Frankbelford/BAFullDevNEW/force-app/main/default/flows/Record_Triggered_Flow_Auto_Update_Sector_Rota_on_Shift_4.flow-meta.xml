    <formulas>
        <name>Payable_End_time_formula</name>
        <dataType>DateTime</dataType>
        <expression>If(ISBLANK({!$Record.sirenum__Billable_End_Time__c}), 
IF(OR({!$Record.IP_CandidateApproved__c},
{!$Record.Actuals_confirmed__c} ), 
{!$Record.sirenum__Actual_End_Time__c},
{!$Record.sirenum__Scheduled_End_Time__c} ), 
{!$Record.sirenum__Billable_End_Time__c} )</expression>
    </formulas>
