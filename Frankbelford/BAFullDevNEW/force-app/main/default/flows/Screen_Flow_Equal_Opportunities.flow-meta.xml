    <formulas>
        <name>asian</name>
        <dataType>String</dataType>
        <expression>IF({!Ethnicitytext} = &quot;Asian or Asian British&quot;, {!Ethnicity_Detailasian}, null)</expression>
    </formulas>
    <formulas>
        <name>black</name>
        <dataType>String</dataType>
        <expression>IF({!Ethnicitytext} = &quot;Black or Black British&quot;, {!Ethnic_Detailblack}, null)</expression>
    </formulas>
    <formulas>
        <name>chinese</name>
        <dataType>String</dataType>
        <expression>IF({!Ethnicitytext} = &quot;Chinese or Chinese British other Ethnic Group&quot;, {!Ethncity_Detailchinese}, null)</expression>
    </formulas>
    <formulas>
        <name>EthnicityDetailNew</name>
        <dataType>String</dataType>
        <expression>IF(
    {!Ethnicitytext} = {!choiceWhite}, {!ethicdetailwhitenew},
    IF(
        {!Ethnicitytext} = {!choiceBlack}, {!Ethnic_Detailblack},
        IF(
            {!Ethnicitytext} = {!choiceChinese}, {!Ethncity_Detailchinese},
            IF(
                {!Ethnicitytext} = {!choiceMixed}, {!Ethnicity_Detail},
                IF(
                    {!Ethnicitytext} = {!choiceAsian}, {!Ethnicity_Detailasian},
                    null
                )
            )
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>mixed4</name>
        <dataType>String</dataType>
        <expression>IF({!Ethnicitytext} = &quot;Mixed&quot;, {!Ethnicity_Detail}, null)</expression>
    </formulas>
    <formulas>
        <name>white4</name>
        <dataType>String</dataType>
        <expression>IF({!Ethnicitytext} = &quot;White&quot;, {!ethicdetailwhitenew}, null)</expression>
    </formulas>
