    <decisions>
        <name>Check_Job_Offer_Status</name>
        <label>Check Job Offer Status</label>
        <locationX>402</locationX>
        <locationY>647</locationY>
        <defaultConnector>
            <targetReference>AddJobOffersToLst</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Job_Offer_Accepted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LoopShiftRelatedJobOffers.sirenum__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Accepted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Rejection_Reason_And_Status</targetReference>
            </connector>
            <label>Is Job Offer Accepted</label>
        </rules>
        <rules>
            <name>Is_Job_Offer_Not_Accepted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LoopShiftRelatedJobOffers.sirenum__Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Accepted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Rejection_Reason</targetReference>
            </connector>
            <label>Is Job Offer Not Accepted</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Shift_Rejection_Criteria</name>
        <label>Check Shift Rejection Criteria</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Shift_Cancelled_by_a_Consultant</name>
            <conditionLogic>1 AND (2 OR 3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.sirenum__Cancelled__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.sirenum__CancellationReason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled by Consultant</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.sirenum__CancellationReason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No Suitable Candidate</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.sirenum__CancellationReason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled by Client</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Job_offers_for_the_Same_Shift</targetReference>
            </connector>
            <label>Is Shift Cancelled by a Consultant</label>
        </rules>
    </decisions>
