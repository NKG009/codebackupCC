        <fields>
            <name>Medical_Text2</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(112, 111, 111); font-size: 16px;&quot;&gt;If you’re applying for work in catering or food production, you are obliged to notify us immediately if you develop any of the following health conditions:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(112, 111, 111); font-size: 16px;&quot;&gt;Recurring stomach or bowel trouble, nasal infection, sore throat, discharging ear, diarrhoea, abdominal pain or fever, any skin conditions affecting the hands, arms or face.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(112, 111, 111); font-size: 16px;&quot;&gt;Do your agree to this requirement?&lt;/span&gt;&lt;/p&gt;</fieldText>
