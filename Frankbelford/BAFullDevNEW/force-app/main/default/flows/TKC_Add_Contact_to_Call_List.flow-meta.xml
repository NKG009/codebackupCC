        <expression>IF(ISBLANK({!GetCallList.Id}), {!CallListRecord.Id}, {!GetCallList.Id} )</expression>
    </formulas>
    <formulas>
        <name>CallListName</name>
        <dataType>String</dataType>
        <expression>LEFT(TEXT(TODAY()) &amp; &apos; - &apos; &amp; {!$User.Username} ,79)</expression>
    </formulas>
    <formulas>
        <name>ExistingCallListMemberNamesAndComma</name>
        <dataType>String</dataType>
        <expression>{!LoopThroughExistingMembers.TKC_Candidate_Name__c} &amp; &apos;, &apos;</expression>
    </formulas>
    <formulas>
        <name>FurtherCandidateIds</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds})=18, &apos;&apos;,
IF(LEN({!CandidateIds})&gt;18,
TRIM(RIGHT({!CandidateIds}, LEN({!CandidateIds}) - FIND(&quot;,&quot;,{!CandidateIds}))),null))</expression>
    </formulas>
    <formulas>
        <name>GetNextCandidateId</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!CandidateIds}) =18, {!CandidateIds},
IF(LEN({!CandidateIds}) &gt;18,
LEFT({!CandidateIds}, FIND(&quot;,&quot;,{!CandidateIds}) - 1),null))</expression>
    </formulas>
    <formulas>
        <name>NonMemberCandidatesFinal</name>
        <dataType>String</dataType>
        <expression>LEFT( {!ExistingCallListMemberContactNames}, LEN({!ExistingCallListMemberContactNames})- 2)</expression>
    </formulas>
    <formulas>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Flow.FaultMessage}),

IF(ISBLANK({!ExistingCallListMemberContactNames}), 
{!$Label.TKC_CandidatesAddedToCallList} &amp; &apos; &apos; &amp; {!CallListDisplayName} &amp; &apos;.&apos;,

IF({!NumberOfCallListMembersCreated} !=0, 
{!$Label.TKC_CandidatesAddedToCallList} &amp; &apos; &apos; &amp; {!CallListDisplayName} &amp; &apos;.&apos; &amp;
{!$Label.TKC_CandidateNotAddedToCallList} &amp; &apos; &apos; &amp;{!ExistingCallListMemberContactNames},

{!$Label.TKC_CandidateNotAddedToCallList} &amp; &apos; &apos; &amp;{!ExistingCallListMemberContactNames}
)
)

,{!$Label.TKC_ErrorMessage})</expression>
    </formulas>
    <formulas>
        <name>Now</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
