    <formulas>
        <name>BeginningOfToday</name>
        <dataType>DateTime</dataType>
        <expression>(DATETIMEVALUE( TEXT(YEAR(TODAY())) + &quot;-&quot; + TEXT(MONTH(TODAY())) + &quot;-&quot; +   TEXT(DAY(TODAY())) + &quot; 00:00:00&quot;))</expression>
