        </connector>
        <fields>
            <name>Title</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255); font-size: 18px; font-family: Arial, sans-serif; color: rgb(119, 119, 119);&quot;&gt;Blue Arrow Reference Survey -&amp;nbsp;{!Reference_Type_1}&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Reference_Consent_Title</name>
            <fieldText>&lt;h3&gt;&lt;b style=&quot;font-size: 12px; color: rgb(102, 102, 102);&quot;&gt;Reference Consent&lt;/b&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 12px; color: rgb(102, 102, 102);&quot;&gt;Referee details are received from prospective candidates using an online form. All candidates agree to the below statement prior to submitting referee details. &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt;{!Get_Reference.Candidate_Name_Text__c}&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102); font-size: 12px; font-family: Arial, sans-serif;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102); font-size: 12px;&quot;&gt;accepted the statement as shown below:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;i style=&quot;background-color: rgb(255, 255, 255); font-size: 12px; color: rgb(102, 102, 102);&quot;&gt;&quot;I acknowledge that Blue Arrow Ltd will verify the contents of my application form and this will include (but not be limited to) asking referees to provide a reference, and this falls into legitimate business interest as defined by the Data Protection Act 2018.&quot;&lt;/i&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Consent_Details_1</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(102, 102, 102);&quot;&gt;Date and Time of Acceptance:  &lt;/b&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;{!Get_Reference.Date_Candidate_Consent_Received__c}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Consent_Details_1a</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt;Candidate Full Name: &lt;/b&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt; {!Get_Reference.Candidate_Name_Text__c}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Signature_1</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(102, 102, 102); background-color: rgb(255, 255, 255);&quot;&gt;Signature: &lt;/b&gt;{!Signature}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Consent_Details_2</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(102, 102, 102);&quot;&gt;National Insurance Number: &lt;/b&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;{!Get_Reference.TR1__Person_Placed__r.sirenum__National_Insurance__c}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <visibilityRule>
                <conditionLogic>or</conditionLogic>
                <conditions>
                    <leftValueReference>Get_Reference.RecordType.Name</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Professional</stringValue>
                    </rightValue>
