                        <elementReference>Academic</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>Consent_Details_3</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt;Date of Birth:  &lt;/b&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt;{!Get_Reference.TR1__Person_Placed__r.Birthdate}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(102, 102, 102);&quot;&gt;  &lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <visibilityRule>
