    <formulas>
        <name>DriversNegligenceUpdatedFormula</name>
        <dataType>Boolean</dataType>
        <expression>ISCHANGED({!$Record.Drivers_Negligence__c} ) || ISNEW()&amp;&amp;
(NOT((ISCHANGED({!$Record.IP_ClientLastPassedToTempest__c}) || ISCHANGED({!$Record.IP_ClientAddressLastPassedToTempest__c}) ||
ISCHANGED({!$Record.GUID_Site__c} ))))</expression>
    </formulas>
    <formulas>
        <name>DriversNegligenceUpdatedFormula11</name>
        <dataType>String</dataType>
