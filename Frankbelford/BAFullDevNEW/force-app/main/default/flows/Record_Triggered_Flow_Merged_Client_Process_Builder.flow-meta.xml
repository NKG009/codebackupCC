    </formulas>
    <formulas>
        <name>SiteandContactonClientReqandExtraCriteriaFormula</name>
        <dataType>Boolean</dataType>
        <expression>(ISCHANGED({!$Record.IP_ClientIDLegacy__c}) || 
ISCHANGED({!$Record.IP_TempestDepartment__c}) ||
ISCHANGED({!$Record.IP_PublicSector__c}) ||
ISCHANGED({!$Record.IP_TempestDepartment__c} ) ||
ISCHANGED({!$Record.Owner:User.IP_TempestDivision__c}) 
)
&amp;&amp; ISBLANK({!$Record.Missing_Site_Details__c})</expression>
    </formulas>
    <formulas>
        <name>SiteandContactonClientRequiredCriteriaFormula</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK({!$Record.IP_TempestDepartment__c} ) )&amp;&amp;
NOT(ISBLANK(TEXT({!$Record.IP_PublicSector__c} )))&amp;&amp;
NOT(ISBLANK({!$Record.IP_TempestDivision__c} ))&amp;&amp;
NOT( ISBLANK({!$Record.IP_ClientIDLegacy__c}))  &amp;&amp;
NOT(ISBLANK({!$Record.Name}))&amp;&amp;
NOT(ISBLANK({!$Record.sirenum__Street_Address__c}))&amp;&amp;
(NOT(ISBLANK({!$Record.sirenum__City__c}))||
NOT(ISBLANK({!$Record.sirenum__Postal_Code__c})))&amp;&amp;
NOT(ISBLANK({!$Record.IP_ClientInvoiceName__c}))&amp;&amp;
NOT(ISBLANK({!$Record.IP_InvoiceAddressStreet__c}))&amp;&amp;
NOT(ISBLANK({!$Record.IP_InvoiceAddressCity__c}))&amp;&amp;
NOT(ISBLANK({!$Record.IP_SalesLedgerNo__c}  ))&amp;&amp;
NOT(ISBLANK({!$Record.IP_InvoiceContactText__c}))&amp;&amp;
NOT(ISBLANK({!$Record.IP_MainContact__c}))&amp;&amp;
ISBLANK({!$Record.Missing_Site_Details__c})&amp;&amp;
NOT(ISBLANK({!$Record.Owners_Department__c} ))</expression>
    </formulas>
    <formulas>
        <name>SitewithContactonClientAddressExtraFormula</name>
        <dataType>Boolean</dataType>
        <expression>(ISCHANGED({!$Record.Name} ) ||
(ISCHANGED({!$Record.sirenum__Street_Address__c} ) &amp;&amp; NOT(PRIORVALUE({!$Record.sirenum__Street_Address__c}) = null)) ||
(ISCHANGED({!$Record.sirenum__City__c} ) &amp;&amp; NOT(PRIORVALUE({!$Record.sirenum__City__c}) = null)) ||
(ISCHANGED({!$Record.sirenum__County__c} ) &amp;&amp; NOT(PRIORVALUE({!$Record.sirenum__County__c}) = null)) ||
(ISCHANGED({!$Record.sirenum__Postal_Code__c} ) &amp;&amp; NOT(PRIORVALUE({!$Record.sirenum__Postal_Code__c}) = null)) ||
ISCHANGED({!$Record.IP_MainContact__c} ) ||
ISCHANGED({!$Record.IP_InvoiceContactText__c}) ||
ISCHANGED({!$Record.IP_InvoiceContactEmail__c}) ||
ISCHANGED({!$Record.IP_InvoiceContactMobile__c} ) ||
ISCHANGED({!$Record.IP_InvoiceContactPhone__c} )
)&amp;&amp; ISBLANK({!$Record.Missing_Site_Details__c})</expression>
    </formulas>
