        <connector>
            <targetReference>Record_Type_UpdateDatePosted</targetReference>
        </connector>
        <object>TR1__Job__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
