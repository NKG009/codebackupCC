{!$Record.IP_PayrollPresentedRateCode__c})
),IF( CONTAINS( {!$Record.sirenum__Shift__r.sirenum__Team__r.sirenum__Job_Type__r.Name}  ,&apos;Cleaner&apos;),&apos;IC&apos;,&apos;IN&apos;))</expression>
