<apex:outputLink styleClass="linkunderline"  rendered="{!TOE = False}" value="{!TOEURL}"
id="theLink06">• <b>Terms Of Employment</b> <br></br></apex:outputLink>   

<apex:outputLink styleClass="linkunderline" rendered="{!med = False}" value="{!FullMedical}"
id="theLink03">• <b>Medical</b> <br></br></apex:outputLink>    

<apex:outputLink styleClass="linkunderline" rendered="{!WTR = False}" value="{!WTRURL}"
id="theLink05">• <b>WTR</b> <br></br></apex:outputLink> 

<apex:outputLink styleClass="linkunderline" rendered="{!newstart = False}" value="{!NSD}"
id="theLink04">• <b>New Starter Declaration</b> <br></br></apex:outputLink> 

<apex:outputLink styleClass="linkunderline" rendered="{!IF(BankDetails = 0 || ActiveBankDetails=1,true,false)}" value="{!BankDetailsURL}"
id="theLink010">• Bank Details(PAYE)<br></br></apex:outputLink> 

