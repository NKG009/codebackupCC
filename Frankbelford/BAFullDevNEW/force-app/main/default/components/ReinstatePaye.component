<apex:outputText value="In line with Blue Arrow’s policy on driving licence checks, we are committed to checking all licences on a rolling three month basis. Please click the link to the DVLA website below to create a ‘check code’, If you can please email me the check code once created (please note it is case sensitive)" rendered="{!IF(allpaycount123 = 1 && certcount123 = true,true,false)}" /> <br></br>
<apex:outputLink styleClass="linkunderline" rendered="{!IF(allpaycount123 = 1 && certcount123 = true,true,false)}" value="https://www.gov.uk/view-driving-licence"
