    <environments>Default</environments>
    <formulas>
        <name>MobileIsChanged</name>
        <dataType>Boolean</dataType>
        <expression>ISCHANGED({!$Record.MobilePhone})</expression>
    </formulas>
    <formulas>
        <name>NewIrelandMobilenumberwithSFformatting</name>
        <dataType>String</dataType>
        <expression>&quot;+353 &quot; &amp; RIGHT({!$Record.MobilePhone}, 10)</expression>
    </formulas>
    <formulas>
        <name>NewMobilenumberwithSFformatting</name>
        <dataType>String</dataType>
        <expression>&quot;+44 &quot; &amp; RIGHT(SUBSTITUTE({!$Record.MobilePhone}, &quot; &quot;, &quot;&quot;), 10)</expression>
    </formulas>
    <formulas>
        <name>NewMobilenumberwithSFformattingOther</name>
        <dataType>String</dataType>
        <expression>IF(
    LEFT({!$Record.MobilePhone}, 4) = &quot;+447&quot;,
    &quot;+44 7&quot; &amp; MID({!$Record.MobilePhone}, 5, 9),
    IF(
        LEFT({!$Record.MobilePhone}, 5) = &quot;+4407&quot;,
        &quot;+44 7&quot; &amp; MID({!$Record.MobilePhone}, 6, 9),
        IF(
            LEFT({!$Record.MobilePhone}, 5) = &quot;+44 7&quot;,
            &quot;+44 7&quot; &amp; MID({!$Record.MobilePhone}, 6, 9),
            {!$Record.MobilePhone}
        )
    )
)</expression>
    </formulas>
