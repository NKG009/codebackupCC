    <screens>
        <name>Welcome_Screen</name>
        <label>Welcome Screen</label>
        <locationX>410</locationX>
        <locationY>99</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
