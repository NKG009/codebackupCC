        <fields>
            <name>Screen3_DISPLAY_0_0_0_0_0_0_0_0_0_0</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 18px; color: rgb(102, 102, 102);&quot;&gt;Bank Details&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Account_Type_Buttons</name>
            <choiceReferences>account_type_set</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Account Type</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <fields>
            <name>Account_Holder</name>
            <dataType>String</dataType>
            <fieldText>Account Holder</fieldText>
            <fieldType>InputField</fieldType>
            <helpText>&lt;p&gt;Name as it appears on the Bank Account or Building Society Account&lt;/p&gt;</helpText>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;b style=&quot;font-size: 14px; color: rgb(211, 0, 0); background-color: rgb(255, 255, 255);&quot;&gt;Account name should not exceed 80 characters.&lt;/b&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>LEN({!Account_Holder})&lt;30</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Account_Number</name>
            <dataType>String</dataType>
            <fieldText>Account Number</fieldText>
            <fieldType>InputField</fieldType>
            <helpText>&lt;p&gt;Account Number should be 8 digits long without spaces eg. 12345678&lt;/p&gt;</helpText>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Account Number must be 8 digits with no spaces&lt;/p&gt;</errorMessage>
                <formulaExpression>REGEX({!Account_Number}, &quot;[0-9]{8}&quot;)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Sort_Code</name>
            <dataType>String</dataType>
            <fieldText>Sort Code</fieldText>
            <fieldType>InputField</fieldType>
            <helpText>&lt;p&gt;Sort Code should be 6 digits with no space eg. 12356&lt;/p&gt;</helpText>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Sort Code must be 6 digits with no spaces&lt;/p&gt;</errorMessage>
                <formulaExpression>REGEX({!Sort_Code}, &quot;[0-9]{6}&quot;)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Building_Society_Roll_No</name>
            <dataType>String</dataType>
            <fieldText>Building Society Roll No.</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>false</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;span style=&quot;font-family: Arial; color: rgb(194, 57, 52); background-color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Building Society Number should be alphanumeric with a minimum of 1 number, no special characters and under 20 characters long.&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>AND(Len({!Building_Society_Roll_No})&lt;20,REGEX({!Building_Society_Roll_No},&quot;(?=.*[0-9])([a-zA-Z0-9+-/]+)&quot;))</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Account_Type_Buttons</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Building Society</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>Tax_Info</name>
            <fieldText>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(102, 102, 102); font-size: 18px; background-color: rgb(255, 255, 255);&quot;&gt;HMRC Tax Information&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Date_of_Birth</name>
            <dataType>Date</dataType>
            <defaultValue>
                <elementReference>Get_Candidate.Birthdate</elementReference>
            </defaultValue>
            <fieldText>Date of Birth</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;b style=&quot;color: rgb(211, 0, 0); font-size: 14px; background-color: rgb(255, 255, 255);&quot;&gt;Age should be greater than 16 and less than 100.&lt;/b&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>YEAR(TODAY())- YEAR({!Date_of_Birth}) &gt; 15</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Tax_Status</name>
            <choiceReferences>TaxA</choiceReferences>
            <choiceReferences>TaxB</choiceReferences>
            <choiceReferences>TaxC</choiceReferences>
            <dataType>String</dataType>
            <fieldText>To ensure you tax code is correct when you start work with us, choose the statement that applies to you, either A, B or C, and tick the appropriate box.</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <fields>
