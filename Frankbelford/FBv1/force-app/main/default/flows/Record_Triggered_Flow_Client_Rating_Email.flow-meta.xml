    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Candidate</targetReference>
        </connector>
        <filterFormula>AND(
    OR(
        TEXT({!$Record.sirenum__Rank__c}) = &quot;Unsuitable&quot;,
        TEXT({!$Record.sirenum__Rank__c}) = &quot;Bad&quot;,
        TEXT({!$Record.sirenum__Rank__c}) = &quot;Average&quot;
    ),
    {!$Record.sirenum__Ranked_by__r.RecordType.Id} = &quot;0120Y000000UW9k&quot;,
    {!$Record.CreatedBy.ProfileId} = &quot;00e4J000000Uq63&quot; 
)</filterFormula>
        <object>sirenum__Ranking__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
