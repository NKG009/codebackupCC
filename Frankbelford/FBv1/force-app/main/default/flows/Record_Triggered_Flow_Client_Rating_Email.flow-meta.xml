    <description>sends email to consultant when client rates candidate 3 or less</description>
    <environments>Default</environments>
    <formulas>
        <name>EmailSubject</name>
        <dataType>String</dataType>
        <expression>&quot;New Client Feedback Provided On &quot; &amp; {!CandidateName} &amp; &quot; by &quot; &amp; {!ClientName1}</expression>
    </formulas>
    <formulas>
        <name>RatedByClient</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    {!$Record.sirenum__Ranked_by__r.RecordType.Id} = &quot;0120Y000000UWBH&quot;, 
    TRUE, 
    FALSE
)</expression>
    </formulas>
    <formulas>
        <name>RecipientEmail</name>
        <dataType>String</dataType>
        <expression>{!$Record.Shift__r.sirenum__Placement__r.IP_Consultant1LookupSplitShare__r.Email}</expression>
    </formulas>
