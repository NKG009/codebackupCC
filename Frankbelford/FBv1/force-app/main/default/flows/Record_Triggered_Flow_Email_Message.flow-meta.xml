    <decisions>
        <name>Check_For_Specific_Email_Message</name>
        <label>Check For Specific Email Message</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Shift_Confirmation_Resend</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Subject</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Blue Arrow Candidate Assignment Confirmation</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RelatedToId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>a3E</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.IsBounced</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_SPlacements</targetReference>
            </connector>
            <label>Is Shift Confirmation Resend</label>
        </rules>
    </decisions>
