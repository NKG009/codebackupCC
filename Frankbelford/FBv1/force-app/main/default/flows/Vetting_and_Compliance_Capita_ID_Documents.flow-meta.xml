        <fields>
            <name>Group1Text</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 12px; color: rgb(102, 102, 102);&quot;&gt;In order to verify your identify we need at least 1 document from the below list of &lt;/span&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255); font-size: 12px; color: rgb(102, 102, 102);&quot;&gt;Accepted forms of Proof Of Address:&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Driving licence&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Bank / Credit card / Builiding Society statement&lt;/strong&gt; – dated within the last 3 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Letter from HMRC, DWP, employment sevice or local authority&lt;/strong&gt; – dated within the last 3 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Payslip&lt;/strong&gt; – dated within the last 3 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Utility bill&lt;/strong&gt; – dated within the last 3 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;P45 , P60&lt;/strong&gt; – dated within the last 12 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Mortgage statement&lt;/strong&gt; – dated within the last 12 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Pension, endowment or ISA statement&lt;/strong&gt; – dated within the last 12 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Child benefit book&lt;/strong&gt; – dated within the last 12 months&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Council tax bill&lt;/strong&gt; – dated within the last 12 months&lt;/li&gt;&lt;/ul&gt;&lt;p style=&quot;text-align: center;&quot;&gt;**Unfortunately, we cannot accept any other forms of POA**&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
