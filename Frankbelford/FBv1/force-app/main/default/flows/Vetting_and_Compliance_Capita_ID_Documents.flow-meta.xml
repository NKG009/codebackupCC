            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(218, 32, 42); font-size: 18px; background-color: rgb(255, 255, 255);&quot;&gt;IDENTIFICATION DOCUMENTATION&lt;/strong&gt;&lt;/p&gt;</fieldText>
