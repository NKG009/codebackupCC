    <decisions>
        <name>Check_the_opt_out_field</name>
        <label>Check the opt-out field</label>
        <locationX>483</locationX>
        <locationY>124</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SMS_Opt_out_field_is_checked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.smagicinteract__SMSOptOut__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_opt_in_consent</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>SMS Opt-out field is checked</label>
        </rules>
        <rules>
            <name>SMS_Opt_Out_is_unchecked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.smagicinteract__SMSOptOut__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Created_consent_with_OptIn</targetReference>
            </connector>
            <label>SMS Opt-Out is unchecked</label>
        </rules>
    </decisions>
