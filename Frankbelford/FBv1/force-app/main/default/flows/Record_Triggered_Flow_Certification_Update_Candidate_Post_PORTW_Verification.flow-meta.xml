    <description>Update key RTW fields on Candidate when PORTW has been verified or lapsed. Flow created to replace the disused RTW workflow &quot;Cert: Verified equals True Record Type PORTW&quot;</description>
    <environments>Default</environments>
    <formulas>
        <name>Citizenship_Group</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.Citizenship_group__c})</expression>
    </formulas>
    <formulas>
        <name>ID_Time_Limited</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.ID_Time_Limited__c})</expression>
    </formulas>
    <formulas>
        <name>National_Insurance</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Get_Candidate.sirenum__National_Insurance__c}),{!$Record.National_Insurance_Number__c}, {!Get_Candidate.sirenum__National_Insurance__c})</expression>
    </formulas>
    <formulas>
        <name>Nationality</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.IP_Nationality__c})</expression>
    </formulas>
    <formulas>
        <name>Verified_Record</name>
        <dataType>String</dataType>
        <expression>{!$User.FirstName} + &quot; &quot; + {!$User.LastName} + &quot;  &quot; + TEXT({!$Flow.CurrentDateTime})</expression>
    </formulas>
