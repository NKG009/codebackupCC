    <textTemplates>
        <name>JobSOQL</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>SELECT Name,Id,User__c,Candidate_ID__c,Candidate_Geolocation__c,Mileage_Radius__c,Active_User__c FROM Search_Preference__c
WHERE
Name = &apos;{!$Record.Job_Category_Text__c}&apos; AND
Notification_Enabled__c = TRUE AND
Active_User__c = TRUE AND
Candidate_Job_Opt_Out__c = FALSE AND
Mileage_Radius__c = {!MileageVariable} AND
Mileage_Radius__c != Null AND
DISTANCE(Candidate_Geolocation__c, GEOLOCATION({!Get_Site.sirenum__Coordinates__Latitude__s},{!Get_Site.sirenum__Coordinates__Longitude__s}), &apos;mi&apos;) &lt; {!MileageVariable}</text>
