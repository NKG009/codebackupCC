&apos;&lt;/td&gt;&lt;td style=&quot;border:1px solid black;&quot;&gt;&apos; + {!Add_Rate_Row.sirenum__Start_Hour__c}+
&apos;&lt;/td&gt;&lt;td style=&quot;border:1px solid black;&quot;&gt;&apos; + {!Add_Rate_Row.sirenum__End_Hour__c}+
&apos;&lt;/td&gt;&lt;td style=&quot;border:1px solid black;&quot;&gt;&apos; + &apos;£&apos;+ TEXT({!Add_Rate_Row.sirenum__Pay_Rate__c})+
&apos;&lt;/td&gt;&lt;td style=&quot;border:1px solid black;&quot;&gt;&apos; + &apos;£&apos; + TEXT({!Add_Rate_Row.sirenum__Overtime_Pay_Rate__c})+
&apos;&lt;/tr&gt;&apos;</expression>
    </formulas>
