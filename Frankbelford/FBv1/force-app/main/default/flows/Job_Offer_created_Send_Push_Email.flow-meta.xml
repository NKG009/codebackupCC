                <leftValueReference>$Record.sirenum__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Failed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.sirenum__Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
