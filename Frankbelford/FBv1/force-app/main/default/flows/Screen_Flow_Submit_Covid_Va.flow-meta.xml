            <fieldText>&lt;p&gt;&lt;strong style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;Proof of Covid-19 Vaccination Status&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px; background-color: rgb(255, 255, 255); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Web&amp;quot;, sans-serif; color: rgb(68, 68, 68);&quot;&gt;It is a requirement of our client that we collect proof of your COVID-19 vaccination status. This data is being requested, solely at the request of our client.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Please use the below tool to upload either:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Proof of medical exemption. &lt;a href=&quot;https://www.gov.uk/guidance/covid-19-medical-exemptions-proving-you-are-unable-to-get-vaccinated&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;Click here&lt;/a&gt; to find out more on acceptable proof of medical exemption&lt;/li&gt;&lt;li&gt;Evidence of being fully vaccinated (2 doses) for Covid-19&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;strong&gt;Please note&lt;/strong&gt; – we require proof of both vaccines therefore if using the NHS app please use the &lt;strong style=&quot;color: rgb(255, 0, 0);&quot;&gt;TRAVEL&lt;/strong&gt; option. &lt;a href=&quot;https://www.gov.uk/guidance/nhs-covid-pass&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;Click here&lt;/a&gt; for further information on how to obtain proof of your vaccines.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Confirm_Vaccine</name>
            <choiceReferences>Choice_Vaccinated</choiceReferences>
            <choiceReferences>Choice_Excemption</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Please confirm your Covid-19 Vaccination status:</fieldText>
            <fieldType>RadioButtons</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
        </fields>
        <fields>
            <name>Is_your_medical_exception_time_limited</name>
            <choiceReferences>Time_Limited_Choice_Yes</choiceReferences>
            <choiceReferences>Time_Limited_Choice_No</choiceReferences>
            <dataType>Boolean</dataType>
            <fieldText>Is your medical exception time-limited?</fieldText>
            <fieldType>RadioButtons</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Confirm_Vaccine</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>Choice_Excemption</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>When_is_it_valid_until</name>
            <dataType>Date</dataType>
            <fieldText>When is it valid until?</fieldText>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;Date cannot be in the past&lt;/p&gt;</errorMessage>
                <formulaExpression>{!When_is_it_valid_until}&gt;={!$Flow.CurrentDate}</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Confirm_Vaccine</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>Choice_Excemption</elementReference>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>Is_your_medical_exception_time_limited</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <booleanValue>true</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
