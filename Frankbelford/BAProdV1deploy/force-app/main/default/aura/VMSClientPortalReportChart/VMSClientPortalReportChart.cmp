<aura:component controller="ReportsController" description="VMSClientPortalReportChart">
    <ltng:require
            scripts="{!$Resource.Chart}"
            afterScriptsLoaded="{!c.afterScriptsLoaded}"/>

    <aura:attribute name="reportId" type="String"/>
    <aura:attribute name="reportName" type="String"/>
    <aura:attribute name="ready" type="Boolean" default="false"/>

    <aura:handler name="init" value="{!this}" action="{! c.doInit}"/>

    <div class="dashboard-section__right-part--singleElement">
        <h2>{!v.reportName}</h2>
        <p>Periodic shift fulfillment by job category</p>
        <div class="slds-grid slds-wrap slds-grid--pull-padded ">
            <div class="slds-p-horizontal--small slds-size--1-of-1 slds-m-top--medium">
                <canvas aura:id="chart" height="300"></canvas>
            </div>
        </div>
    </div>

</aura:component>