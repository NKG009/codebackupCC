<aura:component implements="force:hasRecordId,force:lightningQuickAction" access="global" controller="PortalSiteSetupApx" >
	<aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="message" type="String" />
    <aura:attribute name="error" type="Boolean" />
    <aura:attribute name="success" type="Boolean" />
    <aura:attribute name="processing" type="Boolean" />
    
    <aura:if isTrue="{!v.processing}">
        
        <p style="font-size:15px;color:#1B5297;">
            <center><b><aura:unescapedHtml value="Processing........" /></b></center>
        </p>
    </aura:if>
    <aura:if isTrue="{!v.success}">
        
        <p style="font-size:15px;color:#1B5297;">
            <center><b><aura:unescapedHtml value="{!v.message}" /></b></center>
        </p>
    </aura:if>
    <aura:if isTrue="{!v.error}"> 
        <p style="font-size:15px;color:red;">
            <center><b><aura:unescapedHtml value="{!v.message}" /></b></center>
        </p>
    </aura:if>
</aura:component>