  "customCSS" : ".salesforceIdentityLoginBody2 .cCenterPanel {\n    border-radius: 6px;\n\t-webkit-box-shadow: 0 10px 50px 0 rgba(0,0,0,0.16);\n\t-moz-box-shadow: 0 10px 50px 0 rgba(0,0,0,0.16);\n\tbox-shadow: 0 10px 50px 0 rgba(0,0,0,0.16);\n    max-width: 390px !important;\n    min-width: 360px !important;\n    padding: 32px;\n}\n.salesforceIdentityLoginBody2 .cCenterPanel:before {\n    background-color: transparent !important;\n}\n.salesforceIdentityLoginBody2 .uiButton,\n.salesforceIdentityForgotPassword2 .uiButton {\n    width: 100%;\n    margin-bottom: 5px;\n    color: #fff;\n    background-color: #232323 !important;\n    display: inline-block;\n    text-align: center;\n    vertical-align: middle;\n    border: 1px solid #232323 !important;\n    border-radius: 4px;\n    font-size: 16px;\n    font-family: 'Open Sans', sans-serif;\n    font-weight: 400 !important;\n    line-height: 1.42857143;\n    border-radius: 2px;\n    -webkit-user-select: none;\n    -moz-user-select: none;\n    -ms-user-select: none;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    transition: ease 0.3s background-color, ease 0.3s border;\n}\n\n.salesforceIdentityLoginBody2 .inputContainer:focus-within {\n\tborder: 3px solid #232323;\n}\n\n.salesforceIdentityLoginBody2 .uiButton:hover,\n.salesforceIdentityForgotPassword2 .uiButton:hover {\n\tbackground-color: #fff !important;\n    color: #232323 !important;\n}\n\n.salesforceIdentityLoginForm2 .uiButton:hover .label,\n.salesforceIdentityForgotPassword2 .uiButton:hover .label {\n    color: #232323 !important;\n}\n\n.forceCommunitySection .cb-section_column:only-child {\n    padding: 0 !important;\n}\n.forceCommunitySection .cb-section_row {\n    max-width: 100% !important;\n}\n\n.salesforceIdentityLoginBody2 h1, \n.salesforceIdentityLoginBody2 p {\n\tfont-family: 'Open Sans', sans-serif;\n}\n\n.salesforceIdentityLoginBody2 h1 {\n    font-size: 25px !important; \n    font-weight: 600;\n    letter-spacing: -1px;\n}\n\n.salesforceIdentityLoginBody2 p {\n    font-size: 16px;\n    font-weight: 400;\n}\n\n.salesforceIdentityLoginForm2 .inputContainer,\n.salesforceIdentityForgotPassword2 .inputContainer {\n    background-color: #F4F8F7 !important;\n    border: 0px !important;\n    border-radius: 4px !important;\n\tcolor: #6D6D6D !important;\n    height: 46px !important;\n}\n\n.salesforceIdentityLoginForm2 .inputBox,\n.salesforceIdentityForgotPassword2 .inputContainer .inputBox {\n\tbackground-color: #F4F8F7 !important;\n    margin-top: 0px !important;\n    width: 90% !important;\n}\n\n.salesforceIdentityLoginForm2 a,\n.salesforceIdentityEmployeeLoginLink2.employeeLoginLink a.inverseTextColor,\n.forceCommunityRichText a {\n\tcolor: #005FB2 !important;\n    display: block;\n    font-size: 16px;\n    text-align: center;\n}\n\n.salesforceIdentityLoginForm2 a:hover,\n.salesforceIdentityEmployeeLoginLink2.employeeLoginLink a.inverseTextColor:hover,\n.forceCommunityRichText a:hover {\n    color: #004989 !important;\n\ttext-decoration: underline !important;\n}\n\n.salesforceIdentityForgotPassword2 .inputIcon {\nmargin-top: -3px;    \n}\n\n.salesforceIdentityLoginForm2 .inputIcon {\n    margin-top: 3px;\n}",
