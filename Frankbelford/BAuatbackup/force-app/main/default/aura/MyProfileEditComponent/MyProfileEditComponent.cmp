<aura:component implements="forceCommunity:availableforallpagetypes,forceCommunity:themeLayout,lightning:isUrlAddressable" access="global" controller="MyProfileComponentController">
	<ltng:require styles="{!join(',',
                          $Resource.webUI+'/assets/css/all.css',
                          $Resource.webUI+'/assets/css/fontawesome.css',
                          $Resource.webUI+'/assets/css/fontawesome.min.css',
                          $Resource.webUI+'/assets/css/custom.css',
                          $Resource.Tjcss2+'/assets/css/main.css',
                          $Resource.Tjcss2+'/assets/css/custom.css',
                          $Resource.Tjcss+'/assets/css/dataTables.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery.dataTables.min.css',
                          $Resource.Tjcss+'/assets/css/responsive.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery-ui.css'
                          )
                          }"
                  scripts="{!join(',',
                           $Resource.Tjcss2+'/assets/js/main.min.js',
                           $Resource.Tjcss2+'/assets/js/zoom.js',
                           $Resource.webUI+'/assets/js/custom.js')}"
      />
    <!-- attributes -->
    <aura:attribute name="Name" type="String"/>
    <aura:attribute name="siteList" type="List" access="global"/>
    <aura:attribute name="userInfo" type="User"/>
    <aura:attribute name="siteIdValue" type="String"/>
    <aura:attribute name="displayPopup" type="boolean" access="global" default="false"/>
      <aura:attribute name="site" type="String" /> 
    <!-- hendler -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <head>
        <title>Impellam Project</title>
    </head>
    <body>
		
		
		<div class="container-fluid">
			<nav class="headeNav">
				<div class="visible-xs mobile-nav">
					<img src="{!$Resource.Tjcss + '/assets/img/mobile-nav.png'}" alt="Mobile Icon" title="Click to slide"/>
				</div>
				<a href="" class="logo" title="BlueArrow">
					<img src="{!$Resource.Tjcss + '/assets/img/impellam-logo-blue.png'}" alt="Impellam Logo" Title="Impellam"/>
				</a>

				<ul class="headeNav__right">
			        <li>
			          <a href="" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
			          	<span class="hidden-xs hidden-sm">{!v.userInfo.Name}</span> 
                          
			          	 <aura:if isTrue="{!v.userInfo.User_Image__c != null}">
                                <img src="{!v.userInfo.User_Image__c}" alt=""/>
                                <aura:set attribute="else">
                                    <img src="" class="imag" alt=""/>
                                </aura:set> 
                            </aura:if>
			          	<span class="caret"></span></a>
			          	<ul class="dropdown-menu">
			            	<li><a href="" onclick="{!c.myprofileEditNavigate}" title="My Profile">My Profile</a></li>
			            	<li><a href="" onclick="{!c.siteManagementNavigate}" title="Setting">Site Management</a></li>
			            	<li><a href="" title="Logout" onclick="{!c.logout}">Logout</a></li>
			          	</ul>
			        </li>
		      	</ul>
		      	<div class="col-sm-4 col-md-3 headeNav__selectpicker">
                      <ui:inputSelect aura:id="siteId" class="slselect" label="Site Name" >
                     <aura:iteration items="{!v.siteList}" var="item" >
                            <option text="{!item.label}" value="{!item.value}" selected="{!item.selected}" />
         </aura:iteration>
                    </ui:inputSelect>      
					
				</div>
			</nav>
			<div class="timesheet-section">
				<c:BlueBarComp site="{!v.site}" ></c:BlueBarComp>  


				<div class="timesheet-section__right-part">
					<ol class="breadcrumb">
						<li><a href="" onclick="{!c.dashboardnavigate}" title="Dashboard">Dashboard</a></li>
						<li class="active">My Profile</li>
					</ol>
					<div class="search-section vacancies-section">
						<div class="address-details">
							<form class="row">
								<div class="col-sm-12">
									<h2>Personal Details:</h2>
								</div>
                                <div class="col-sm-12 text-right" style="imagedisplay">
                                    <aura:if isTrue="{!v.userInfo.User_Image__c != null}">
                                        <img src="{!v.userInfo.User_Image__c}" alt="" style="max-width: 30%;"/>
                                        <aura:set attribute="else">
                                            <img src="/profilephoto/005/T" alt=""  style="width:120px;"/>
                                        </aura:set>
                                    </aura:if>
                                	<c:fileupload recordId="{!v.siteIdValue}" />
                                </div>
								<div class="col-sm-12">
									<label class="global-label">First Name</label>
                                    <input type="text" class="global-input" name="Date" value="{!v.userInfo.FirstName}" placeholder="First Name"  id="firstNameId"/>
								</div>
                                <div class="col-sm-12">
									<label class="global-label">Last Name</label>
                                    <input type="text" class="global-input" name="Date" value="{!v.userInfo.LastName}" placeholder="Last Name"  id="lastNameId"/>
								</div>
								<div class="col-sm-12">
									<label class="global-label">Job Title</label>
                                    <input type="text" class="global-input" name="Date" value="{!v.userInfo.Title}" placeholder="Job Title" id="titleId"/>
								</div>
								<div class="col-sm-12">
									<label class="global-label">Email</label>
									<input type="email" class="global-input" name="Date" value="{!v.userInfo.Email}" placeholder="Email" id="emailId"/>
								</div>
								<div class="col-sm-12">
									<label class="global-label">Mobile</label>
									<input type="text" class="global-input" name="phone" value="{!v.userInfo.MobilePhone}" placeholder="Mobile" id="mobilephoneId"/>
      							</div>
								<div class="col-sm-12">
									<label class="global-label">Phone</label>
									<input type="text" class="global-input" name="phone1" value="{!v.userInfo.Phone}" placeholder="Phone" id="phoneId"/>
								</div>
								<div class="col-sm-12">
                                    <hr/>
								</div>
								<div class="col-sm-12">
									<h2>Address:</h2>
								</div>
								<div class="col-sm-12">
									<label class="global-label">Address line 1</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.Street}" placeholder="" id="streetId"/>
								</div>
                                <div class="col-sm-12">
									<label class="global-label">Address line 2</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.Address_Line_2__c}" placeholder="" id="addressline2Id"/>
								</div>
                                <div class="col-sm-12">
									<label class="global-label">City</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.City}" placeholder="" id="cityId"/>
								</div>
                                <div class="col-sm-12">
									<label class="global-label">County</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.State}" placeholder="" id="stateId"/>
								</div>								
								<div class="col-sm-12">
									<label class="global-label">Country</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.Country}" placeholder="" id="countryId"/>
								</div>
								<div class="col-sm-12">
									<label class="global-label">Postcode</label>
									<input type="text" class="global-input" name="Date" value="{!v.userInfo.PostalCode}" placeholder="" id="postalCodeId"/>
								</div>
								<div class="col-sm-12">
                                    <hr/>
								</div>
                                
								<div class="col-sm-12 text-right">
									<!--<button type="submit" class="action-button accept" onclick="{!c.submitLoggedInuserInfo}">Submit</button>-->
                                    <span class="edit_action popup-btn" data-toggle="modal" data-target="#myProfileid-popup" id="updateSitebtnId" >
        								<lightning:button value="Submit" label="Submit" onclick="{!c.submitLoggedInuserInfo}" class="action-button accept"/>
    								</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                    <span>
				      					<lightning:button iconName="utility:close" label="Close" class="action-button edit" variant="Brand" onclick="{!c.myprofileEditNavigate}" /> 
                                    </span>
                                    <span>
                                        <lightning:button label="Clear" type="reset" class="action-button decline" variant="Brand"/> 
                         			</span>
								</div>
							</form>
						</div>
					</div>
					<footer>
						<div class="row">
							<div class="col-sm-6"><p> &copy; Blue Arrow, All rights reserved 2019.</p></div>
							<div class="col-sm-6"><p>Regd Address:  800 The Boulevard, Capability Green, Luton, Bedfordshire, LU1 3BA. Company No. 00641659</p></div>
						</div>
					</footer>
				</div>
			</div>
		</div>
		<div class="sidenav-overlay"></div>
		<div class="search-overlay"></div>
        <!-- Modal Popup when Profile updated -->
        <aura:if isTrue="{!v.displayPopup}">
            <div class="custom-model modal fade" id="myProfileid-popup" tabindex="-1" role="dialog" aria-labelledby="bookedTemp-popup">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <p>Profile has been updated succesfully!</p><br/>
                        <button type="button" label="Close" class="action-button decline" data-dismiss="modal" onclick="{!c.myprofilesaveview}" style="background-color: #706e6f!important;">Close</button>
                    </div>
                </div>
            </div>
       </aura:if>
	</body>
</aura:component>