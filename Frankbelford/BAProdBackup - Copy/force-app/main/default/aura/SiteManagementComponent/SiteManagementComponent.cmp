<aura:component implements="forceCommunity:availableForAllPageTypes,forceCommunity:themeLayout" access="global" controller="SiteManagementComponentController">
    
    <ltng:require styles="{!join(',',
                          $Resource.webUI+'/assets/css/all.css',
                          $Resource.webUI+'/assets/css/fontawesome.css',
                          $Resource.webUI+'/assets/css/fontawesome.min.css',
                          $Resource.webUI+'/assets/css/custom.css',
                          $Resource.Tjcss2+'/assets/css/main.css',
                          $Resource.Tjcss2+'/assets/css/custom.css',
                          $Resource.Tjcss+'/assets/css/dataTables.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery.dataTables.min.css',
                          $Resource.Tjcss+'/assets/css/responsive.bootstrap.min.css',
                          $Resource.Tjcss+'/assets/css/jquery-ui.css'
                          )
                          }"
                  scripts="{!join(',',
                           $Resource.Tjcss2+'/assets/js/main.min.js',
                           $Resource.Tjcss2+'/assets/js/zoom.js',
                           $Resource.webUI+'/assets/js/custom.js')}"
      />
    
    <!-- attributes -->
    <aura:attribute name="selectedSite" type="String"/>
    <aura:attribute name="userInfo" type="User"/>
    <aura:attribute name="siteInfo" type="sirenum__Site__c"/>
    <aura:attribute name="Linksite" type="list"/>
    <aura:attribute name="siteList" type="List" access="global"/>
    <aura:attribute name="site" type="String" /> 
    
    <!-- hendler -->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <head>
        <title>Impellam Project</title>
    </head>
    <body>		
        
        <div class="container-fluid">
            
            <nav class="headeNav">
                <div class="visible-xs mobile-nav">
                    <img src="{!$Resource.Tjcss + '/assets/img/mobile-nav.png'}" alt="Mobile Icon" title="Click to slide"/>
                </div>
                <a href="" class="logo" title="BlueArrow">
                    <img src="{!$Resource.Tjcss + '/assets/img/impellam-logo-blue.png'}" alt="Impellam Logo" Title="Impellam"/>
                </a> 
                
                <ul class="headeNav__right">
                    <li>
                        <a href="" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
                            <span class="hidden-xs hidden-sm">{!v.userInfo.Name}</span> 
                            <aura:if isTrue="{!v.userInfo.User_Image__c != null}">
                                <img src="{!v.userInfo.User_Image__c}" alt=""/>
                                <aura:set attribute="else">
                                    <img src="" class="imag" alt=""/>
                                </aura:set> 
                            </aura:if>
                            <span class="caret"></span></a>
                        <ul class="dropdown-menu">
                            <li><a href="" onclick="{!c.myProfileNavigate}" title="My Profile">My Profile</a></li>
                            <li><a href="" onclick="{!c.siteManagementNavigate}" title="Setting">Site Management</a></li>
                            <li><a href="" onclick="{!c.logout}" title="Logout">Logout</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="col-sm-4 col-md-3 headeNav__selectpicker">
                    <ui:inputSelect aura:id="siteId" class="slselect" label="Site Name" change="{! c.getSiteInfo }">
                        <aura:iteration items="{!v.siteList}" var="item" >
                            <option text="{!item.label}" value="{!item.value}" selected="{!item.selected}" />
                        </aura:iteration>
                    </ui:inputSelect>     
                    
                </div>
            </nav>
            <div class="timesheet-section">
                
                <c:BlueBarComp site="{!v.site}" ></c:BlueBarComp>  
                
                <div class="timesheet-section__right-part">
                    <ol class="breadcrumb">
                        <li><a href="javascript:void(0)" onclick="{!c.dashboardnavigate}" title="Dashboard">Dashboard</a></li>
                        <li class="active">Site Management</li>
                    </ol>
                    <div class="search-section vacancies-section">
                        <div class="address-details">
                            <form class="row">
                                <!--
                               <div class="col-sm-12 text-right">
                                    <button type="button" class="action-button edit" onclick="{!c.openActionWindow}">Edit</button>
                                </div> -->
                                <div class="col-sm-12">
                                    <h2>Site Address:</h2>
                                </div>
                                 
                                <div class="col-sm-12">
                                    <label class="global-label">Address Lines</label>
                                    <p>{!v.siteInfo.sirenum__Street_Address__c}</p>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">City</label>
                                    <p>{!v.siteInfo.sirenum__City__c}</p>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">County</label>
                                    <p>{!v.siteInfo.sirenum__County__c}</p>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">Country</label>
                                    <p>{!v.siteInfo.sirenum__Country__c}</p>
                                </div>
                                <div class="col-sm-12">
                                    <label class="global-label">Postcode</label>
                                    <p>{!v.siteInfo.sirenum__Postal_Code__c}</p>
                                </div>
                                <div class="col-sm-12">
                                    <hr/>
                                </div>
                                <div class="col-sm-12">
                                    <h2>Main Contact:</h2>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">First Name</label>
                                    <p>{!v.siteInfo.IP_MainContact__r.FirstName}</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Last Name</label>
                                    <p>{!v.siteInfo.IP_MainContact__r.LastName}</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Email</label>
                                    <p>{!v.siteInfo.IP_MainContact__r.Email}</p>
                                </div>
                                <div class="col-sm-12">
                                    <hr/>
                                </div>
                                <!--	<div class="col-sm-12">
         <h2>Secondary Approver:</h2>
        </div>
        <div class="col-sm-6">
         <label class="global-label">First Name</label>
         <p>{!v.siteInfo.IP_InvoiceContact__r.FirstName}</p>
        </div>
                                <div class="col-sm-6">
         <label class="global-label">Last Name</label>
         <p>{!v.siteInfo.IP_InvoiceContact__r.LastName}</p>
        </div>
        <div class="col-sm-6">
         <label class="global-label">Email</label>
         <p>{!v.siteInfo.IP_InvoiceContact__r.Email}</p>
        </div>
        <div class="col-sm-12">
                                    <hr/>
                                </div> -->
                                <div class="col-sm-12">
                                    <h2>Emergency Contact:</h2>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">First Name</label>
                                    <p>{!v.siteInfo.Emergency_Contact__r.FirstName}</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Last Name</label>
                                    <p>{!v.siteInfo.Emergency_Contact__r.LastName}</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="global-label">Email</label>
                                    <p>{!v.siteInfo.Emergency_Contact__r.Email}</p>
                                </div>
                                <div class="col-sm-12">
                                    <hr/>
                                </div>
                                <!--
                                <div class="col-sm-12 text-right">
                                    <button type="button" class="action-button edit" onclick="{!c.openActionWindow}">Edit</button>
                                </div>
								-->
                            </form>
                            <!--       start from here -->
                            <div  >
                                <p class="slds-truncate" style=" color: #00aae3;font-size: 2.4rem;">List of Approvers:
                                </p>
                                <form class="row">
                                    <aura:iteration items="{!v.Linksite}" var="link"  indexVar="i" >
                                        <!--  <div class="col-sm-12">
                                            <p class="slds-truncate" style="font-size: 2.0rem; margin-bottom: 1.5rem; font-weight: bold;">Approver {!i+1}
                                            </p>
                                        </div>-->
                                        <div class="slds-card__body">
                                            <div class="col-sm-6">
                                                <label class="global-label" style="font-weight: bold;">First Name</label>
                                                <p>{!link.IP_Contact__r.FirstName}</p>
                                                
                                            </div>
                                            <div class="col-sm-6">
                                                <label class="global-label" style="font-weight: bold;">Last Name</label>
                                                <p>{!link.IP_Contact__r.LastName}</p>
                                                
                                            </div>
                                            <div class="col-sm-6">
                                                
                                                <label class="global-label" style="font-weight: bold;">Email</label>
                                                <p>{!link.IP_Contact__r.Email}</p>
                                                
                                            </div>
                                            <div class="col-sm-6">
                                                <label class="global-label" style="font-weight: bold;">Portal Type</label>
                                                <p>{!link.IP_PortalType__c}</p>
                                                
                                            </div>
                                        </div>
                                        
                                        <hr/>
                                        
                                    </aura:iteration>
                                </form>
                            </div>
                            
                            <!--       End  here -->
                        </div>
                    </div>
                    
                    <footer>
                        <div class="row">
                            <div class="col-sm-6"><p> &copy; Blue Arrow, All rights reserved 2019.</p></div>
                            <div class="col-sm-6"><p>Regd Address:  800 The Boulevard, Capability Green, Luton, Bedfordshire, LU1 3BA. Company No. 00641659</p></div>
                        </div>
                    </footer>
                    
                </div>
            </div>
        </div>
        <div class="sidenav-overlay"></div>
        <div class="search-overlay"></div>		
    </body>
</aura:component>