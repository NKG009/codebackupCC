<aura:component controller="Booked_Temps_Cnt" implements="forceCommunity:themeLayout,force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
   
    <ltng:require styles="{!join(',',
                              $Resource.assetsTest+'/assets/css/all.css',
                              $Resource.Tjcss2+'/assets/css/main.css',
                              $Resource.webUI+'/assets/css/fontawesome.css',
                              $Resource.webUI+'/assets/css/fontawesome.min.css'
                              )
                              }" 
                      scripts="{!join(',',
                               $Resource.Tjcss2+'/assets/js/main.min.js',    
                               $Resource.Tjcss2+'/assets/js/custom.js'
                               )}"
                      />
   
        <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute type="List" name="allshifts" />
    <aura:attribute type="String" name="site" />
    

    
    
   
    
    <div class="ElementDetail">
            <div class="ElementDetail__table ElementDetail__table3">
                <table>
                    <thead>
                        <tr>
                            <th>Temp Name</th>
                            <th>Date</th>
                            <th>Job Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        <aura:iteration items="{!v.allshifts}" var="shifts">
                            <tr>
                                
                                <td data-th="Temp Name" data-toggle="modal" data-target="{!'#bookedTemp-popup'+(shifts.shiftId)}"><a href="" >{!shifts.TempName}</a></td>
                                <td data-th="Date"><lightning:formattedDateTime value="{!shifts.TempDate}" year="numeric" month="numeric" day="numeric" /></td>
                                <td data-th="Job Role">{!shifts.jobRole}</td>
                            </tr>
                            
                        </aura:iteration>
                        
                    </tbody>
                </table>
            </div>
        </div>
        <button type="submit" class="query-btn" onclick="{!c.redirectBookTemp}">View All</button>
        
        
        
        <!-- booked Temp Popup -->
        <aura:iteration items="{!v.allshifts}" var="shifts">
            <div class="custom-model modal fade" id="{!'bookedTemp-popup'+(shifts.shiftId)}" tabindex="-1" role="dialog" aria-labelledby="bookedTemp-popup">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        <h1>Skills</h1>
                        <h3>{!shifts.TempName}</h3>
                        <div class="ElementDetail__table">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Competency Type</th>
                                        <th>Valid From</th>
                                        <th>Valid To</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!shifts.skillList}" var="skill">
                                        <tr>
                                            <td data-th="Competency Type">{!skill.sirenum__TicketType__r.Name}</td>
                                            <td data-th="Valid From"><lightning:formattedDateTime value="{!skill.sirenum__Valid_from__c}" year="numeric" month="numeric" day="numeric" /></td>
                                            <td data-th="Valid To"><lightning:formattedDateTime value="{!skill.sirenum__Valid_until__c}" year="numeric" month="numeric" day="numeric" /></td>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
        </aura:iteration>
   
</aura:component>