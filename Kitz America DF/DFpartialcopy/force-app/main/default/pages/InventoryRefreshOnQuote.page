<apex:page controller="InventoryRefreshOnQuoteController"
    showHeader="false"
    sidebar="false"
    lightningStylesheets="true"
    action="{!refreshInventory}"
    docType="html-5.0"
>

    <apex:slds />

    <div class="slds-p-around_large slds-align_absolute-center">

        <!-- Loading -->
        <apex:outputPanel rendered="{!isLoading}">
            <div id="spinner" class="demo-only demo-only demo-only_viewport demo--inverse" style="height:6rem; z-index:1000; position: fixed;">
                <div class="slds-spinner_container slds-is-fixed">
                <div role="status" class="slds-spinner slds-spinner_medium slds-spinner_brand">
                    <span class="slds-assistive-text">Loading</span>
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
                </div>
            </div>
            <p class="slds-text-heading_medium slds-m-top_medium">
                Refreshing inventory, please wait...
            </p>
        </apex:outputPanel>

        <!-- Success -->
        <apex:outputPanel rendered="{!NOT(isLoading)}">
            <apex:form >

                <p class="slds-text-heading_medium slds-text-color_success">
                    ✅ Inventory refresh complete.
                </p>

                <!-- Changes Found -->
                <apex:outputPanel rendered="{!changedLines.size > 0}">
                    <div class="slds-box slds-m-top_medium">
                        <p class="slds-text-title_bold slds-m-bottom_small">
                            Updated Quote Lines
                        </p>

                        <apex:repeat value="{!changedLines}" var="cl">
                            <p>
                                🔹 Line <b>{!cl.lineNumber}</b> :
                                Qty changed from
                                <b>{!cl.oldQty}</b>
                                →
                                <b>{!cl.newQty}</b>
                            </p>
                        </apex:repeat>
                    </div>
                </apex:outputPanel>

                <!-- No Changes -->
                <apex:outputPanel rendered="{!changedLines.size = 0}">
                    <p class="slds-m-top_medium slds-text-color_weak">
                        No inventory changes were detected.
                    </p>
                </apex:outputPanel>

                <!-- OK Button -->
                <div class="slds-m-top_large slds-align_absolute-center">
                    <apex:commandButton value="OK"
                        action="{!redirecttoqle}"
                        styleClass="slds-button slds-button_brand"
                    />
                </div>

            </apex:form>
        </apex:outputPanel>

    </div>

</apex:page>