      "componentAttributes" : {
        "richTextValue" : "<p style=\"text-align: center;\"><strong style=\"font-size: 36px; font-family: arial; color: rgb(0, 102, 204);\">Welcome!</strong></p><p><br></p><p style=\"text-align: justify;\"><br></p><p style=\"text-align: justify;\"><span style=\"font-size: 16px; font-family: arial;\">Welcome to the KITZ Corporation of America customer access site. From this site you will be able to access many current and future web based services including access to catalogs, technical literature, inventory, MTR's and order status.</span></p><p style=\"text-align: justify;\"><span style=\"font-size: 16px; font-family: arial;\">In order to view and/or print the documents on this site you will need to have Adobe Acrobat Reader installed on your computer. Click here and follow the directions on the screen to download and install the free version of Adobe Acrobat.</span></p><ol><li style=\"text-align: justify;\"><span style=\"font-size: 16px; font-family: arial;\">We invite you to provide us with feedback about our site. Please feel free to contact us via our feedback page. If you are having technical difficulties while accessing any of the features on this site, please send an email to davido@kitz.com.</span></li></ol><p>&nbsp;</p>"
